@model AutoSalon.ViewModels.AdminCarViewModel
@{
    ViewData["Title"] = "Редактировать автомобиль";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<form method="post" action="/admin/cars/@Model.Id/edit" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm p-4 mb-4">
                <h5 class="fw-bold mb-3">Основные данные</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Марка *</label>
                        <input asp-for="Brand" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Модель *</label>
                        <input asp-for="Model" class="form-control" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Год *</label>
                        <input asp-for="Year" type="number" class="form-control" min="1990" max="@DateTime.Now.Year" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Цена (₸) *</label>
                        <input asp-for="Price" type="number" class="form-control" min="0" required />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Пробег (км)</label>
                        <input asp-for="Mileage" type="number" class="form-control" min="0" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Объём (л)</label>
                        <input asp-for="EngineVolume" type="number" step="0.1" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Кузов</label>
                        <select asp-for="BodyType" class="form-select">
                            <option value="">—</option>
                            <option>Седан</option><option>Кроссовер</option><option>Внедорожник</option>
                            <option>Хэтчбек</option><option>Минивэн</option><option>Купе</option><option>Пикап</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Коробка</label>
                        <select asp-for="Transmission" class="form-select">
                            <option value="">—</option>
                            <option>Автомат</option><option>Механика</option><option>Вариатор</option><option>Робот</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Привод</label>
                        <select asp-for="DriveType" class="form-select">
                            <option value="">—</option>
                            <option>Передний</option><option>Задний</option><option>Полный</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Топливо</label>
                        <select asp-for="FuelType" class="form-select">
                            <option value="">—</option>
                            <option>Бензин</option><option>Дизель</option><option>Гибрид</option><option>Электро</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Цвет</label>
                        <input asp-for="Color" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Город</label>
                        <input asp-for="City" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Описание</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    </div>
                </div>
            </div>

            <!-- Существующие фото -->
            @if (Model.ExistingPhotos.Any())
            {
                <div class="card border-0 shadow-sm p-4 mb-4">
                    <h5 class="fw-bold mb-1">Фотографии</h5>
                    <p class="text-muted small mb-3">Перетащите для изменения порядка. Первое фото — главное.</p>
                    <div class="photo-grid d-flex flex-wrap gap-2" data-car-id="@Model.Id">
                        @foreach (var photo in Model.ExistingPhotos)
                        {
                            <div class="photo-item position-relative" data-photo-id="@photo.Id" draggable="true"
                                 style="width:110px;cursor:grab">
                                <img src="@photo.FilePath" style="width:110px;height:80px;object-fit:cover;border-radius:8px;border:@(photo.IsMain ? "2px solid #185FA5" : "2px solid transparent")" />
                                @if (photo.IsMain)
                                {
                                    <span style="position:absolute;top:4px;left:4px;background:#185FA5;color:#fff;font-size:9px;padding:1px 5px;border-radius:6px">Главное</span>
                                }
                                <div class="d-flex gap-1 mt-1">
                                    @if (!photo.IsMain)
                                    {
                                        <button type="button" class="btn btn-xs btn-outline-primary flex-fill"
                                                style="font-size:10px;padding:1px 4px"
                                                onclick="setMain(@photo.Id)">Главное</button>
                                    }
                                    <button type="button" class="btn btn-xs btn-outline-danger flex-fill"
                                            style="font-size:10px;padding:1px 4px"
                                            onclick="delPhoto(@photo.Id, this)">✕</button>
                                </div>
                            </div>
                        }
                    </div>
                    @Html.AntiForgeryToken()
                </div>
            }

            <!-- Новые фото -->
            <div class="card border-0 shadow-sm p-4">
                <h5 class="fw-bold mb-2">Добавить фото</h5>
                <input type="file" name="Photos" class="form-control" multiple accept="image/*" />
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-4 mb-4">
                <h5 class="fw-bold mb-3">Статус</h5>
                <div class="mb-3">
                    <label class="form-label">Статус продажи</label>
                    <select asp-for="Status" class="form-select">
                        <option value="0">Активный (продаётся)</option>
                        <option value="2">Резерв</option>
                        <option value="1">Продано</option>
                    </select>
                </div>
                <div class="form-check">
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label class="form-check-label" asp-for="IsActive">Показывать на сайте</label>
                </div>
            </div>

            <div class="card border-0 shadow-sm p-4">
                <h5 class="fw-bold mb-3">Бейджи</h5>
                <div class="form-check mb-2">
                    <input asp-for="IsVerified" class="form-check-input" type="checkbox" />
                    <label class="form-check-label" asp-for="IsVerified">✔ Проверено</label>
                </div>
                <div class="form-check mb-2">
                    <input asp-for="HasWarranty" class="form-check-input" type="checkbox" />
                    <label class="form-check-label" asp-for="HasWarranty">🛡 Гарантия</label>
                </div>
                <div class="mb-2">
                    <label class="form-label small">Дней гарантии</label>
                    <input asp-for="WarrantyDays" type="number" class="form-control form-control-sm" />
                </div>
                <div class="form-check">
                    <input asp-for="HasExchange" class="form-check-input" type="checkbox" />
                    <label class="form-check-label" asp-for="HasExchange">🔄 Обмен</label>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-fill">Сохранить</button>
                <a href="/admin/cars" class="btn btn-outline-secondary">Назад</a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<script src="~/js/gallery.js"></script>
<script>
var carId = @Model.Id;
var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

async function delPhoto(photoId, btn) {
    if (!confirm('Удалить это фото?')) return;
    btn.disabled = true;
    await fetch('/admin/cars/' + carId + '/photos/' + photoId + '/delete', {
        method: 'POST',
        headers: { 'RequestVerificationToken': token }
    });
    btn.closest('.photo-item').remove();
}

async function setMain(photoId) {
    await fetch('/admin/cars/' + carId + '/photos/' + photoId + '/setmain', {
        method: 'POST',
        headers: { 'RequestVerificationToken': token }
    });
    location.reload();
}
</script>
}
