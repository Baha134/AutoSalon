@model AutoSalon.ViewModels.AdminCarViewModel
@{
    ViewData["Title"] = "Добавить автомобиль";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<form method="post" action="/admin/cars/create" enctype="multipart/form-data" novalidate>
    @Html.AntiForgeryToken()

    <div class="row g-4">
        <div class="col-lg-8">

            <partial name="_CarFormFields" model="Model" />

            <!-- Фото -->
            <div class="card border-0 shadow-sm p-4">
                <h5 class="fw-bold mb-3">Фотографии</h5>
                <input type="file" name="Photos" class="form-control"
                       multiple accept="image/*" />
                <div class="text-muted small mt-2">
                    Можно загрузить несколько фото. Первое фото станет главным.
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-4">
                <button type="submit" class="btn btn-primary w-100 mb-2">
                    Сохранить
                </button>
                <a href="/admin/cars" class="btn btn-outline-secondary w-100">
                    Отмена
                </a>
            </div>
        </div>
    </div>
</form>