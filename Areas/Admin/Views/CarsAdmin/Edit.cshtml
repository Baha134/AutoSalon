@model AutoSalon.ViewModels.AdminCarViewModel
@{
    ViewData["Title"] = "Редактировать автомобиль";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<form method="post" action="/admin/cars/@Model.Id/edit" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="row g-4">
        <div class="col-lg-8">

            <partial name="_CarFormFields" model="Model" />

            <!-- Существующие фото -->
            @if (Model.ExistingPhotos.Any())
            {
                <div class="card border-0 shadow-sm p-4 mb-4">
                    <h5 class="fw-bold mb-1">Фотографии</h5>
                    <p class="text-muted small mb-3">
                        Перетащите для изменения порядка. Первое фото — главное.
                    </p>
                    <div class="photo-grid d-flex flex-wrap gap-2" data-car-id="@Model.Id">
                        @foreach (var photo in Model.ExistingPhotos)
                        {
                            <div class="photo-item position-relative" data-photo-id="@photo.Id"
                                 draggable="true" style="width:110px;cursor:grab">
                                <img src="@photo.FilePath"
                                     style="width:110px;height:80px;object-fit:cover;border-radius:8px;
                                border:@(photo.IsMain ? "2px solid #D4AF37" : "2px solid #2a2a2a")"
                                     alt="" loading="lazy" />

                                @if (photo.IsMain)
                                {
                                    <span style="position:absolute;top:4px;left:4px;background:#D4AF37;
                                        color:#000;font-size:9px;padding:2px 6px;
                                        border-radius:6px;pointer-events:none;font-weight:600;">
                                        Главное
                                    </span>
                                }

                                <button type="button"
                                        onclick="delPhoto(@photo.Id, this)"
                                        title="Удалить фото"
                                        style="position:absolute;top:3px;right:3px;width:22px;height:22px;
                                    border-radius:50%;background:rgba(239,68,68,0.85);
                                    color:#fff;border:none;font-size:13px;line-height:1;
                                    display:flex;align-items:center;justify-content:center;
                                    cursor:pointer;padding:0">
                                    ✕
                                </button>

                                @if (!photo.IsMain)
                                {
                                    <button type="button"
                                            onclick="setMain(@photo.Id)"
                                            title="Сделать главным"
                                            style="position:absolute;bottom:3px;left:3px;right:3px;
                                        background:rgba(212,175,55,0.9);color:#000;border:none;
                                        font-size:9px;padding:2px 4px;border-radius:4px;
                                        cursor:pointer;text-align:center;font-weight:600;">
                                        Сделать главным
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Новые фото -->
            <div class="card border-0 shadow-sm p-4">
                <h5 class="fw-bold mb-2">Добавить фото</h5>
                <input type="file" name="Photos" class="form-control"
                       multiple accept="image/*" />
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-4">
                <button type="submit" class="btn btn-primary w-100 mb-2">
                    Сохранить
                </button>
                <a href="/admin/cars" class="btn btn-outline-secondary w-100">
                    Назад
                </a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        var carId = @Model.Id;
        var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';

        async function delPhoto(photoId, btn) {
            if (!confirm('Удалить это фото?')) return;
            btn.disabled = true;
            const res = await fetch('/admin/cars/' + carId + '/photos/' + photoId + '/delete', {
                method: 'POST',
                headers: { 'RequestVerificationToken': token }
            });
            if (res.ok) {
                btn.closest('.photo-item').remove();
            } else {
                btn.disabled = false;
                alert('Ошибка удаления');
            }
        }

        async function setMain(photoId) {
            await fetch('/admin/cars/' + carId + '/photos/' + photoId + '/setmain', {
                method: 'POST',
                headers: { 'RequestVerificationToken': token }
            });
            location.reload();
        }

        (function () {
            const grid = document.querySelector('.photo-grid');
            if (!grid) return;

            let dragging = null;

            grid.addEventListener('dragstart', e => {
                dragging = e.target.closest('.photo-item');
                if (dragging) dragging.style.opacity = '0.5';
            });

            grid.addEventListener('dragover', e => {
                e.preventDefault();
                const target = e.target.closest('.photo-item');
                if (target && target !== dragging) {
                    const rect = target.getBoundingClientRect();
                    const after = e.clientX > rect.left + rect.width / 2;
                    grid.insertBefore(dragging, after ? target.nextSibling : target);
                }
            });

            grid.addEventListener('dragend', async () => {
                if (dragging) dragging.style.opacity = '';
                dragging = null;

                const ids = [...grid.querySelectorAll('.photo-item')]
                    .map(el => parseInt(el.dataset.photoId));

                await fetch('/admin/cars/' + carId + '/photos/reorder', {
                    method: 'PATCH',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(ids)
                });
            });
        })();
    </script>
}