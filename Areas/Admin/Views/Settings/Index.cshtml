@model AutoSalon.Models.SalonSettings
@{
    ViewData["Title"] = "Настройки салона";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <form method="post" action="/admin/settings">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="card border-0 shadow-sm p-4 mb-4">
                <h5 class="fw-bold mb-3">🏢 Салон</h5>
                <div class="mb-3">
                    <label class="form-label">Название салона</label>
                    <input asp-for="SalonName" class="form-control" placeholder="Автопрайм" />
                    <div class="form-text">Отображается в шапке и подвале сайта</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Телефон (для сайта)</label>
                    <input asp-for="Phone" class="form-control" placeholder="+7 (777) 123-45-67" />
                    <div class="form-text">Показывается в шапке и футере главной страницы</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" placeholder="info@autosalon.kz" />
                </div>
            </div>

            <div class="card border-0 shadow-sm p-4 mb-4">
                <h5 class="fw-bold mb-3">📞 Контакты</h5>
                <div class="mb-3">
                    <label class="form-label">Телефон</label>
                    <input asp-for="PhoneNumber" class="form-control" placeholder="+7 (000) 000-00-00" />
                </div>
                <div class="mb-3">
                    <label class="form-label">WhatsApp (номер без +, пробелов)</label>
                    <input asp-for="WhatsAppNumber" class="form-control" placeholder="70000000000" />
                    <div class="form-text">Например: 70001234567</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Адрес</label>
                    <input asp-for="Address" class="form-control" placeholder="г. Кокшетау, ул. Примерная, д. 1" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Режим работы</label>
                    <input asp-for="WorkingHours" class="form-control" placeholder="Пн–Вс: 9:00 — 20:00" />
                </div>
            </div>

            <div class="card border-0 shadow-sm p-4 mb-4">
                <h5 class="fw-bold mb-3">📬 Telegram-уведомления</h5>
                <div class="alert alert-info small">
                    Для получения уведомлений о новых заявках создайте бота через @@BotFather и получите токен.
                    Затем добавьте бота в чат и найдите Chat ID.
                </div>
                <div class="mb-3">
                    <label class="form-label">Telegram Bot Token</label>
                    <input asp-for="TelegramBotToken" class="form-control" placeholder="1234567890:ABC..." type="password" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Telegram Chat ID</label>
                    <input asp-for="TelegramChatId" class="form-control" placeholder="-1001234567890" />
                </div>
            </div>

            <div class="card border-0 shadow-sm p-4 mb-4">
                <h5 class="fw-bold mb-3">🏦 Кредитный калькулятор</h5>
                <div class="mb-3">
                    <label class="form-label">Ставка кредита (% годовых)</label>
                    <input asp-for="CreditRate" type="number" step="0.1" min="1" max="100" class="form-control" />
                    <div class="form-text">Используется в калькуляторе на сайте</div>
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100">💾 Сохранить настройки</button>
        </form>
    </div>
</div>
