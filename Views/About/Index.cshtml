@model AutoSalon.Models.SalonSettings
@{
    ViewData["Title"] = "О нас";
    ViewData["Description"] = "Автосалон — проверенные автомобили с гарантией. Контакты, адрес, режим работы.";
}

<div class="container mt-4">
    <h1 class="h3 fw-bold mb-4">О нас</h1>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm p-4 mb-4">
                <h2 class="h5 fw-bold mb-3">🏢 Наш автосалон</h2>
                <p>Мы занимаемся продажей автомобилей с пробегом и новых автомобилей. Каждый автомобиль проходит техническую проверку перед продажей. Помогаем с оформлением кредита, страховки и регистрацией.</p>
                <ul class="list-unstyled">
                    <li class="mb-2">✅ Проверка по базам ГИБДД и истории ДТП</li>
                    <li class="mb-2">🏦 Кредит от @Model.CreditRate% годовых</li>
                    <li class="mb-2">🔄 Обмен вашего автомобиля (trade-in)</li>
                    <li class="mb-2">🛡 Гарантия на все автомобили</li>
                    <li class="mb-2">📄 Помощь в оформлении документов</li>
                </ul>
            </div>

            <!-- Антимошеннический блок -->
            <div class="fraud-warning mb-4">
                <strong>⚠️ Внимание! Защита от мошенников</strong>
                <ul class="mt-2 mb-0">
                    <li>Мы <strong>никогда</strong> не просим перевести предоплату онлайн или на карту физического лица</li>
                    <li>Все договоры оформляются только в нашем офисе, при личной встрече</li>
                    <li>Не передавайте деньги незнакомым людям, которые представляются нашими сотрудниками</li>
                    <li>Если вас просят о предоплате — это мошенники. Немедленно свяжитесь с нами для проверки.</li>
                </ul>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-sm p-4">
                <h2 class="h5 fw-bold mb-3">📞 Контакты</h2>
                <div class="mb-3">
                    <div class="text-muted small mb-1">Телефон</div>
                    <a href="tel:@Model.PhoneNumber?.Replace(" ", "").Replace("(", "").Replace(")", "").Replace("-", "")"
                       class="fw-bold fs-5 text-decoration-none">@Model.PhoneNumber</a>
                </div>
                @if (!string.IsNullOrEmpty(Model.WhatsAppNumber))
                {
                    <div class="mb-3">
                        <div class="text-muted small mb-1">WhatsApp</div>
                        <a href="https://wa.me/@Model.WhatsAppNumber" target="_blank" class="btn btn-sm" style="background:#25D366;color:#fff">
                            💬 Написать в WhatsApp
                        </a>
                    </div>
                }
                <div class="mb-3">
                    <div class="text-muted small mb-1">Адрес</div>
                    <div>@Model.Address</div>
                </div>
                <div class="mb-3">
                    <div class="text-muted small mb-1">Режим работы</div>
                    <div>@Model.WorkingHours</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Карта -->
    <div class="mt-4">
        <h2 class="h5 fw-bold mb-3">🗺 Как нас найти</h2>
        <div style="border-radius:12px;overflow:hidden;height:350px;background:#eee;display:flex;align-items:center;justify-content:center">
            <div class="text-muted">
                <p class="text-center">Карта будет здесь</p>
                <p class="text-center small">Вставьте iframe от Яндекс Карты или Google Maps</p>
            </div>
        </div>
    </div>

    <!-- Форма заявки -->
    <div class="row justify-content-center mt-5" id="lead-anchor">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm p-4">
                <h3 class="fw-bold mb-1">Оставить заявку</h3>
                <p class="text-muted small mb-4">Мы перезвоним в рабочее время</p>
                <form class="lead-form" method="post" action="/leads">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="LeadType" value="Call" />
                    <input type="text" name="Website" style="display:none" tabindex="-1" autocomplete="off" />
                    <div class="mb-3">
                        <input type="text" name="Name" class="form-control" placeholder="Ваше имя" required maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <input type="tel" name="Phone" class="form-control" placeholder="+7 (___) ___-__-__" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Отправить заявку</button>
                </form>
            </div>
        </div>
    </div>
</div>