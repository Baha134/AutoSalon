@using AutoSalon.Models
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AutoSalon.Resources.SharedResource> L
@model SalonSettings
@{
    ViewData["Title"] = L["Calc_Title"].ToString();
    ViewData["Description"] = L["Calc_Subtitle"].ToString();
    var defaultRate = Model?.CreditRate ?? 18m;
}

<!-- Hero секция (как на других страницах) -->
<div class="calc-page-hero" style="background: var(--color-bg-secondary); padding: 48px 0; text-align: center; border-bottom: 1px solid var(--color-border); margin-top: 72px;">
    <div class="container">
        <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 4vw, 2.5rem); font-weight: 800;">
            @L["Calc_Title_Part1"] <span style="color: var(--color-accent);">@L["Calc_Title_Part2"]</span>
        </h1>
        <p style="color: var(--color-text-secondary); max-width: 560px; margin: 12px auto 0;">@L["Calc_Subtitle"]</p>
    </div>
</div>

<!-- Основной контейнер -->
<div class="container" style="padding: 48px 0 80px;">
    <div id="full-calculator">
        <div class="calc-layout" style="display: grid; grid-template-columns: 360px 1fr; gap: 32px; align-items: start;">

            <!-- ЛЕВАЯ ПАНЕЛЬ: параметры -->
            <div class="calc-panel" style="background: var(--color-bg-secondary); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: 28px; position: sticky; top: 96px;">
                <div class="calc-panel-title" style="font-weight: 800; margin-bottom: 24px; font-size: 1.2rem;">@L["Calc_Panel_Title"]</div>

                <!-- Цена -->
                <div class="fc-field" style="margin-bottom: 24px;">
                    <label class="fc-label" style="font-size: 0.75rem; text-transform: uppercase; color: var(--color-accent); margin-bottom: 6px; display: block;">@L["Calc_CarPrice"]</label>
                    <div class="fc-input-wrap" style="position: relative;">
                        <input type="text" id="fc-price" value="3 000 000" autocomplete="off" style="width: 100%; background: var(--color-bg-elevated); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 10px 40px 10px 14px; color: var(--color-text-primary);" />
                        <span class="fc-input-unit" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: var(--color-text-muted);">₸</span>
                    </div>
                    <div class="fc-range-row" style="display: flex; gap: 12px; margin-top: 8px;">
                        <input type="range" id="fc-price-range" min="500000" max="50000000" step="100000" value="3000000" style="flex: 1; accent-color: var(--color-accent);" />
                        <span class="fc-range-label" style="color: var(--color-text-muted); font-size: 0.75rem;">50M</span>
                    </div>
                </div>

                <!-- Первоначальный взнос -->
                <div class="fc-field" style="margin-bottom: 24px;">
                    <label class="fc-label" style="font-size: 0.75rem; text-transform: uppercase; color: var(--color-accent); margin-bottom: 6px; display: block;">@L["Calc_DownPayment"]</label>
                    <div class="fc-input-wrap" style="position: relative;">
                        <input type="text" id="fc-down" value="600 000" autocomplete="off" style="width: 100%; background: var(--color-bg-elevated); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 10px 40px 10px 14px; color: var(--color-text-primary);" />
                        <span class="fc-input-unit" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: var(--color-text-muted);">₸</span>
                    </div>
                    <div class="fc-range-row" style="display: flex; gap: 12px; margin-top: 8px;">
                        <input type="range" id="fc-down-range" min="0" max="80" step="1" value="20" style="flex: 1; accent-color: var(--color-accent);" />
                        <span class="fc-range-label" id="fc-down-pct-label" style="color: var(--color-text-muted); font-size: 0.75rem;">20%</span>
                    </div>
                </div>

                <!-- Ставка -->
                <div class="fc-field" style="margin-bottom: 24px;">
                    <label class="fc-label" style="font-size: 0.75rem; text-transform: uppercase; color: var(--color-accent); margin-bottom: 6px; display: block;">@L["Calc_Rate"]</label>
                    <div class="fc-input-wrap" style="position: relative;">
                        <input type="number" id="fc-rate" value="@defaultRate" min="1" max="60" step="0.5" style="width: 100%; background: var(--color-bg-elevated); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 10px 40px 10px 14px; color: var(--color-text-primary);" />
                        <span class="fc-input-unit" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: var(--color-text-muted);">%</span>
                    </div>
                    <div class="fc-range-row" style="display: flex; gap: 12px; margin-top: 8px;">
                        <input type="range" id="fc-rate-range" min="1" max="60" step="0.5" value="@defaultRate" style="flex: 1; accent-color: var(--color-accent);" />
                        <span class="fc-range-label" id="fc-rate-label" style="color: var(--color-text-muted); font-size: 0.75rem;">@defaultRate%</span>
                    </div>
                </div>

                <!-- Срок -->
                <div class="fc-field" style="margin-bottom: 24px;">
                    <label class="fc-label" style="font-size: 0.75rem; text-transform: uppercase; color: var(--color-accent); margin-bottom: 6px; display: block;">@L["Calc_Term"]</label>
                    <div class="fc-periods" style="display: flex; flex-wrap: wrap; gap: 8px;">
                        <button class="fc-period-btn" data-months="12" style="background: transparent; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 6px 12px; cursor: pointer; transition: var(--transition-fast);">12 @L["Calc_Months_Suffix"]</button>
                        <button class="fc-period-btn" data-months="24" style="background: transparent; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 6px 12px; cursor: pointer;">24 @L["Calc_Months_Suffix"]</button>
                        <button class="fc-period-btn fc-active" data-months="36" style="background: var(--color-accent); border-color: var(--color-accent); color: #0A0C12; border-radius: var(--radius-md); padding: 6px 12px; cursor: pointer;">36 @L["Calc_Months_Suffix"]</button>
                        <button class="fc-period-btn" data-months="48" style="background: transparent; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 6px 12px; cursor: pointer;">48 @L["Calc_Months_Suffix"]</button>
                        <button class="fc-period-btn" data-months="60" style="background: transparent; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 6px 12px; cursor: pointer;">60 @L["Calc_Months_Suffix"]</button>
                        <button class="fc-period-btn" data-months="84" style="background: transparent; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 6px 12px; cursor: pointer;">84 @L["Calc_Months_Suffix"]</button>
                    </div>
                </div>

                <!-- Страховка -->
                <div class="fc-field" style="margin-bottom: 0;">
                    <label class="fc-label" style="font-size: 0.75rem; text-transform: uppercase; color: var(--color-accent); margin-bottom: 6px; display: block;">@L["Calc_Insurance"] <small style="font-weight:400; text-transform:none;">@L["Calc_Insurance_Sub"]</small></label>
                    <div class="fc-input-wrap" style="position: relative;">
                        <input type="text" id="fc-insurance" value="0" autocomplete="off" style="width: 100%; background: var(--color-bg-elevated); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 10px 40px 10px 14px; color: var(--color-text-primary);" />
                        <span class="fc-input-unit" style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: var(--color-text-muted);">₸</span>
                    </div>
                </div>
            </div>

            <!-- ПРАВАЯ ПАНЕЛЬ: результаты, графики, таблица -->
            <div>
                <!-- Блок с метриками -->
                <div class="calc-results" style="background: var(--color-bg-secondary); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: 24px; margin-bottom: 24px;">
                    <div class="calc-results-title" style="font-weight: 700; margin-bottom: 16px; font-size: 1rem;">@L["Calc_Result_Title"]</div>
                    <div class="fc-metrics" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">
                        <div class="fc-metric fc-metric-highlight" style="background: rgba(212,175,55,0.1); border: 1px solid var(--color-accent); border-radius: var(--radius-lg); padding: 16px; text-align: center;">
                            <div class="fc-metric-label" style="font-size: 0.7rem; text-transform: uppercase; color: var(--color-text-muted);">@L["Calc_Monthly"]</div>
                            <div class="fc-metric-value" id="fc-monthly" style="font-size: 1.5rem; font-weight: 800; color: var(--color-accent);">—</div>
                            <div class="fc-metric-sub" style="font-size: 0.7rem; color: var(--color-text-muted);">@L["Calc_Annuity"]</div>
                        </div>
                        <div class="fc-metric" style="background: var(--color-bg-elevated); border-radius: var(--radius-lg); padding: 16px; text-align: center;">
                            <div class="fc-metric-label" style="font-size: 0.7rem; text-transform: uppercase; color: var(--color-text-muted);">@L["Calc_LoanAmt"]</div>
                            <div class="fc-metric-value" id="fc-loan-amt" style="font-size: 1.2rem; font-weight: 700;">—</div>
                            <div class="fc-metric-sub" id="fc-down-pct" style="font-size: 0.7rem;">@L["Calc_DownPayment"] —%</div>
                        </div>
                        <div class="fc-metric" style="background: var(--color-bg-elevated); border-radius: var(--radius-lg); padding: 16px; text-align: center;">
                            <div class="fc-metric-label" style="font-size: 0.7rem; text-transform: uppercase; color: var(--color-text-muted);">@L["Calc_Overpay"]</div>
                            <div class="fc-metric-value" id="fc-overpay" style="font-size: 1.2rem; font-weight: 700;">—</div>
                            <div class="fc-metric-sub" id="fc-overpay-pct" style="font-size: 0.7rem;">— @L["Calc_OfAmount"]</div>
                        </div>
                    </div>
                    <div style="margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--color-border); display: flex; justify-content: space-between;">
                        <span style="color: var(--color-text-muted);">@L["Calc_Total"]</span>
                        <span style="font-weight: 800; color: var(--color-accent);" id="fc-total">—</span>
                    </div>
                    <p style="font-size: 0.7rem; color: var(--color-text-muted); margin-top: 12px;">@L["Calc_Disclaimer"]</p>
                </div>

                <!-- Вкладки: график / таблица -->
                <div class="calc-chart-section" style="background: var(--color-bg-secondary); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: 24px; margin-bottom: 24px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                        <div class="calc-section-title" style="font-weight: 700;">@L["Calc_Chart_Title"]</div>
                        <div class="fc-tabs" style="display: flex; gap: 8px;">
                            <button class="fc-tab fc-tab-active" id="fc-tab-chart" style="background: var(--color-accent); border: none; border-radius: var(--radius-md); padding: 6px 14px; cursor: pointer; font-weight: 600;">@L["Calc_Tab_Chart"]</button>
                            <button class="fc-tab" id="fc-tab-table" style="background: transparent; border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: 6px 14px; cursor: pointer;">@L["Calc_Tab_Table"]</button>
                        </div>
                    </div>

                    <!-- График -->
                    <div id="fc-view-chart">
                        <div class="fc-legend" style="display: flex; gap: 20px; margin-bottom: 16px;">
                            <div style="display: flex; align-items: center; gap: 6px; font-size: 0.75rem;"><span style="width: 10px; height: 10px; background: #1a5fb4; border-radius: 2px;"></span> @L["Calc_Legend_Principal"]</div>
                            <div style="display: flex; align-items: center; gap: 6px; font-size: 0.75rem;"><span style="width: 10px; height: 10px; background: #c0392b; border-radius: 2px;"></span> @L["Calc_Legend_Interest"]</div>
                            <div style="display: flex; align-items: center; gap: 6px; font-size: 0.75rem;"><span style="width: 10px; height: 10px; background: #27ae60; border-radius: 50%;"></span> @L["Calc_Legend_Balance"]</div>
                        </div>
                        <div style="position: relative; width: 100%; height: 280px;">
                            <canvas id="fc-bar-chart" role="img" aria-label="@L["Calc_Chart_Title"]">@L["Calc_Loading"]</canvas>
                        </div>
                    </div>

                    <!-- Таблица платежей -->
                    <div id="fc-view-table" style="display: none;">
                        <div class="fc-table-wrap" style="border: 1px solid var(--color-border); border-radius: var(--radius-lg); overflow: hidden;">
                            <div style="max-height: 400px; overflow-y: auto;">
                                <table class="fc-table" style="width: 100%; border-collapse: collapse; background: var(--color-bg-elevated);">
                                    <thead style="background: var(--color-bg-secondary);">
                                        <tr>
                                            <th style="padding: 12px; text-align: left;">@L["Calc_Table_Date"]</th>
                                            <th style="padding: 12px; text-align: right;">@L["Calc_Table_Payment"]</th>
                                            <th style="padding: 12px; text-align: right;">@L["Calc_Table_Principal"]</th>
                                            <th style="padding: 12px; text-align: right;">@L["Calc_Table_Interest"]</th>
                                            <th style="padding: 12px; text-align: right;">@L["Calc_Table_Balance"]</th>
                                        </tr>
                                    </thead>
                                    <tbody id="fc-sched-body">
                                        <tr><td colspan="5" style="padding: 20px; text-align: center;">@L["Calc_Loading"]</td></tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Диаграмма "тело кредита / переплата" -->
                <div class="calc-chart-section" style="background: var(--color-bg-secondary); border: 1px solid var(--color-border); border-radius: var(--radius-xl); padding: 24px;">
                    <div class="calc-section-title" style="margin-bottom: 20px; font-weight: 700;">@L["Calc_Donut_Title"]</div>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; align-items: center;">
                        <div style="position: relative; height: 160px;">
                            <canvas id="fc-donut-chart" role="img" aria-label="@L["Calc_Donut_Title"]">@L["Calc_Loading"]</canvas>
                        </div>
                        <div>
                            <div style="margin-bottom: 16px;">
                                <div style="font-size: 0.7rem; text-transform: uppercase; color: var(--color-text-muted);">@L["Calc_Body_Principal"]</div>
                                <div style="font-size: 1.2rem; font-weight: 800; color: #1a5fb4;" id="fc-loan-amt2">—</div>
                            </div>
                            <div style="margin-bottom: 16px;">
                                <div style="font-size: 0.7rem; text-transform: uppercase; color: var(--color-text-muted);">@L["Calc_Overpay"]</div>
                                <div style="font-size: 1.2rem; font-weight: 800; color: #c0392b;" id="fc-overpay2">—</div>
                            </div>
                            <div>
                                <div style="font-size: 0.7rem; text-transform: uppercase; color: var(--color-text-muted);">@L["Calc_Total"]</div>
                                <div style="font-size: 1.2rem; font-weight: 800; color: var(--color-accent);" id="fc-total2">—</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        // Небольшой вспомогательный скрипт для синхронизации процентов (оставлен как в оригинале)
        var downRange = document.getElementById('fc-down-range');
        var downLabel = document.getElementById('fc-down-pct-label');
        if (downRange && downLabel) {
        downRange.addEventListener('input', function() {
        downLabel.textContent = downRange.value + '%';
        });
        }
        var rateRange2 = document.getElementById('fc-rate-range');
        var rateLabel2 = document.getElementById('fc-rate-label');
        if (rateRange2 && rateLabel2) {
        rateRange2.addEventListener('input', function() {
        rateLabel2.textContent = parseFloat(rateRange2.value).toFixed(1) + '%';
        });
        }
    </script>
    <script src="~/js/calculator.js" asp-append-version="true"></script>
    <script>
        (function() {
        var observer = new MutationObserver(function() {
        var a = document.getElementById('fc-loan-amt');
        var b = document.getElementById('fc-loan-amt2');
        if (a && b && b.textContent !== a.textContent) b.textContent = a.textContent;

        var c = document.getElementById('fc-overpay');
        var d = document.getElementById('fc-overpay2');
        if (c && d && d.textContent !== c.textContent) d.textContent = c.textContent;

        var e = document.getElementById('fc-total');
        var f = document.getElementById('fc-total2');
        if (e && f && f.textContent !== e.textContent) f.textContent = e.textContent;
        });
        var targets = ['fc-loan-amt','fc-overpay','fc-total'].map(function(id) {
        return document.getElementById(id);
        }).filter(Boolean);
        targets.forEach(function(t) { observer.observe(t, { childList: true, characterData: true, subtree: true }); });
        })();
    </script>
}