@model AutoSalon.ViewModels.CarDetailViewModel

@{
    var car = Model.Car;
    var settings = Model.Settings;
    var isSold = car.Status == AutoSalon.Models.CarStatus.Sold;
    var isReserved = car.Status == AutoSalon.Models.CarStatus.Reserved;
    var canBuy = !isSold && !isReserved;
    var photos = car.Photos.OrderBy(p => p.SortOrder).ToList();
    var mainPhoto = car.MainPhoto;
    ViewData["Title"] = $"{car.Brand} {car.Model} {car.Year}";
    ViewData["Description"] = $"{car.Brand} {car.Model} {car.Year} г., {car.DisplayMileage}, {car.EngineVolume} л — {car.DisplayPrice}";
    ViewData["OgTitle"] = $"{car.Brand} {car.Model} {car.Year}";
    ViewData["OgDescription"] = ViewData["Description"];
    ViewData["OgImage"] = mainPhoto?.FilePath ?? "";
}

<div class="container mt-3">

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb small">
            <li class="breadcrumb-item"><a href="/">@L["Detail_Home"]</a></li>
            <li class="breadcrumb-item"><a href="/catalog">@L["Detail_Catalog"]</a></li>
            <li class="breadcrumb-item active">@car.Brand @car.Model @car.Year</li>
        </ol>
    </nav>

    <div class="car-detail-layout">

        <div>
            @if (isSold)
            {
                <div class="alert alert-danger mb-3">@L["Detail_Sold_Alert"]</div>
            }
            else if (isReserved)
            {
                <div class="alert alert-warning mb-3">@L["Detail_Reserved_Alert"]</div>
            }

            <!-- Галерея -->
            <div class="gallery-wrap gallery" id="car-gallery">
                <div class="gallery-main position-relative">
                    @if (photos.Any())
                    {
                        <img class="gallery-main" src="@photos[0].FilePath" alt="@car.Brand @car.Model" id="main-photo" />
                        <button class="gallery-nav gallery-prev" onclick="galleryPrev()">‹</button>
                        <button class="gallery-nav gallery-next" onclick="galleryNext()">›</button>
                        <div class="gallery-counter"><span id="photo-idx">1</span> / @photos.Count</div>
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center" style="height:300px;background:#eee;color:#aaa">
                            @L["Detail_NoPhoto"]
                        </div>
                    }
                </div>
                @if (photos.Count > 1)
                {
                    <div class="gallery-thumbs">
                        @for (var i = 0; i < photos.Count; i++)
                        {
                            <img class="gallery-thumb @(i == 0 ? "active" : "")"
                                 src="@photos[i].FilePath"
                                 data-src="@photos[i].FilePath"
                                 data-idx="@i"
                                 alt="@(i + 1)" />
                        }
                    </div>
                }
            </div>

            <!-- Характеристики -->
            <h2 class="fw-bold mt-4 mb-1">@car.Brand @car.Model @car.Year</h2>

            @if (car.Badge != null)
            {
                <div class="car-badges mb-3">
                    @if (car.Badge.IsVerified)
                    {
                        <span class="car-badge badge-verified">@L["Detail_Verified"]</span>
                    }
                    @if (car.Badge.HasWarranty)
                    {
                        <span class="car-badge badge-warranty">@string.Format(L["Detail_Warranty"], car.Badge.WarrantyDays)</span>
                    }
                    @if (car.Badge.HasExchange)
                    {
                        <span class="car-badge badge-exchange">@L["Detail_Exchange"]</span>
                    }
                    @if (car.Badge.HistoryReportUrl != null)
                    {
                        <a class="car-badge badge-verified" href="@car.Badge.HistoryReportUrl" target="_blank" rel="noopener">@L["Detail_History"]</a>
                    }
                </div>
            }

            <div class="car-specs-grid">
                <div class="spec-item"><div class="spec-key">@L["Detail_Year"]</div><div class="spec-val">@car.Year</div></div>
                <div class="spec-item"><div class="spec-key">@L["Detail_Mileage"]</div><div class="spec-val">@car.DisplayMileage</div></div>
                <div class="spec-item"><div class="spec-key">@L["Detail_Engine"]</div><div class="spec-val">@car.EngineVolume л, @car.FuelType</div></div>
                <div class="spec-item"><div class="spec-key">@L["Detail_Transmission"]</div><div class="spec-val">@car.Transmission</div></div>
                <div class="spec-item"><div class="spec-key">@L["Detail_Drive"]</div><div class="spec-val">@car.DriveType</div></div>
                <div class="spec-item"><div class="spec-key">@L["Detail_Body"]</div><div class="spec-val">@car.BodyType</div></div>
                <div class="spec-item"><div class="spec-key">@L["Detail_Color"]</div><div class="spec-val">@car.Color</div></div>
                <div class="spec-item"><div class="spec-key">@L["Detail_City"]</div><div class="spec-val">@car.City</div></div>
            </div>

            @if (!string.IsNullOrEmpty(car.Description))
            {
                <div class="mt-4">
                    <h3 class="h5 fw-bold">@L["Detail_Description"]</h3>
                    <p class="text-muted">@car.Description</p>
                </div>
            }

            <!-- Калькулятор -->
            @if (canBuy)
            {
                <div class="calculator-box" id="calculator"
                     data-price="@car.Price"
                     data-car-id="@car.Id">
                    <h3>@L["Detail_Calc_Title"]</h3>
                    <div class="calc-slider-group">
                        <label>@L["Detail_Calc_Down"] <strong id="down-label">20%</strong></label>
                        <input type="range" id="calc-down" min="10" max="90" value="20" step="5" />
                    </div>
                    <div class="calc-slider-group">
                        <label>@L["Detail_Calc_Months"] <strong id="months-label">60 @L["Detail_Calc_Months_Label"]</strong></label>
                        <input type="range" id="calc-months" min="12" max="120" value="60" step="12" />
                    </div>
                    <div class="calc-result" id="calc-result">
                        <div><div class="r-label">@L["Detail_Calc_Monthly"]</div><div class="r-val" id="r-monthly">—</div></div>
                        <div><div class="r-label">@L["Detail_Calc_Downpay"]</div><div class="r-val" id="r-down">—</div></div>
                        <div><div class="r-label">@L["Detail_Calc_Overpay"]</div><div class="r-val" id="r-over">—</div></div>
                    </div>
                </div>
            }

            <!-- Похожие авто -->
            @if (Model.Similar.Any())
            {
                <div class="mt-5">
                    <h3 class="h5 fw-bold mb-3">@L["Detail_Similar"]</h3>
                    <div class="car-grid">
                        @foreach (var sim in Model.Similar.Take(3))
                        {
                            <partial name="_CarCard" model="sim" />
                        }
                    </div>
                </div>
            }
        </div>

        <!-- ПРАВАЯ КОЛОНКА -->
        <div>
            <div class="car-cta-box">
                <div class="car-cta-price">
                    @if (isSold)
                    {
                        <span class="text-muted text-decoration-line-through">@car.DisplayPrice</span>
                    }
                    else
                    {
                        @car.DisplayPrice
                    }
                </div>

                @if (canBuy)
                {
                    <div class="car-cta-monthly">@L["Detail_Monthly_From"] <span id="cta-monthly">—</span> @L["Detail_Monthly_Suffix"]</div>
                }

                @if (canBuy)
                {
                    <div id="lead-anchor">
                        <a href="tel:@settings?.PhoneNumber?.Replace(" ", "").Replace("(", "").Replace(")", "").Replace("-", "")"
                           class="cta-btn cta-call">@L["Detail_Call"]</a>

                        @if (!string.IsNullOrEmpty(settings?.WhatsAppNumber))
                        {
                            <a href="https://wa.me/@settings.WhatsAppNumber" target="_blank" rel="noopener"
                               class="cta-btn cta-whatsapp">@L["Detail_WhatsApp"]</a>
                        }

                        <button class="cta-btn cta-credit" onclick="document.getElementById('calculator')?.scrollIntoView({behavior:'smooth'})">@L["Detail_CalcCredit"]</button>

                        <div class="cta-actions">
                            <button class="cta-fav" onclick="toggleFav(event, @car.Id, this)">@L["Detail_Favorite"]</button>
                            <button class="cta-compare" onclick="toggleCompare(event, @car.Id, this)">@L["Detail_Compare"]</button>
                        </div>

                        <div class="mt-4">
                            <h5 class="fw-bold mb-3">@L["Detail_LeaveRequest"]</h5>
                            <form class="lead-form" method="post" action="/leads">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="CarId" value="@car.Id" />
                                <input type="hidden" name="LeadType" value="Call" />
                                <input type="text" name="Website" style="display:none" tabindex="-1" autocomplete="off" />
                                <div class="mb-2">
                                    <input type="text" name="Name" class="form-control form-control-sm" placeholder="@L["Detail_Form_Name"]" required maxlength="100" />
                                </div>
                                <div class="mb-2">
                                    <input type="tel" name="Phone" class="form-control form-control-sm" placeholder="@L["Detail_Form_Phone"]" required />
                                </div>
                                <div class="mb-2">
                                    <textarea name="Message" class="form-control form-control-sm" rows="2" placeholder="@L["Detail_Form_Comment"]"></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary w-100">@L["Detail_Form_Submit"]</button>
                            </form>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary text-center">
                        @(isSold ? L["Detail_Status_Sold"] : L["Detail_Status_Reserved"])
                    </div>
                    <a href="/catalog" class="btn btn-primary w-100">@L["Detail_Other_Cars"]</a>
                }

                <div class="fraud-warning mt-3">
                    <strong>@L["Detail_Fraud_Title"]</strong>
                    @L["Detail_Fraud_Text"]
                </div>

                @if (settings != null)
                {
                    <div class="mt-3 small text-muted">
                        <div>📍 @settings.Address</div>
                        <div>⏰ @settings.WorkingHours</div>
                    </div>
                }
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var box = document.getElementById('calculator');
            if (box) {
                var price = parseFloat(box.dataset.price) || 0;
                var downSlider = document.getElementById('calc-down');
                var monthsSlider = document.getElementById('calc-months');
                var downLabel = document.getElementById('down-label');
                var monthsLabel = document.getElementById('months-label');
                var rMonthly = document.getElementById('r-monthly');
                var rDown = document.getElementById('r-down');
                var rOver = document.getElementById('r-over');
                var ctaMonthly = document.getElementById('cta-monthly');
                var monthsSuffix = '@L["Detail_Calc_Months_Label"]';

                function fmt(n) { return Number(n).toLocaleString('ru-RU') + ' ₸'; }

                async function recalc() {
                    var downPct = parseInt(downSlider.value);
                    var months = parseInt(monthsSlider.value);
                    downLabel.textContent = downPct + '%';
                    monthsLabel.textContent = months + ' ' + monthsSuffix;
                    try {
                        var res = await fetch('/api/calculator?price=' + price + '&downPct=' + downPct + '&months=' + months);
                        if (!res.ok) return;
                        var d = await res.json();
                        if (rMonthly) rMonthly.textContent = fmt(d.monthly);
                        if (rDown) rDown.textContent = fmt(d.downAmount);
                        if (rOver) rOver.textContent = fmt(d.overpay);
                        if (ctaMonthly) ctaMonthly.textContent = fmt(d.monthly);
                    } catch(e) { console.error('Calc error', e); }
                }

                downSlider.addEventListener('input', recalc);
                monthsSlider.addEventListener('input', recalc);
                recalc();
            }

            var photos = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(photos.Select(p => p.FilePath).ToList()));
            var currentIdx = 0;

            function setPhoto(idx) {
                if (idx < 0) idx = photos.length - 1;
                if (idx >= photos.length) idx = 0;
                currentIdx = idx;
                var mainImg = document.getElementById('main-photo');
                var idxEl = document.getElementById('photo-idx');
                if (mainImg) mainImg.src = photos[idx];
                if (idxEl) idxEl.textContent = idx + 1;
                document.querySelectorAll('.gallery-thumb').forEach(function(t, i) {
                    t.classList.toggle('active', i === idx);
                });
            }

            window.galleryPrev = function() { setPhoto(currentIdx - 1); };
            window.galleryNext = function() { setPhoto(currentIdx + 1); };
            document.querySelectorAll('.gallery-thumb').forEach(function(t) {
                t.addEventListener('click', function() { setPhoto(parseInt(this.dataset.idx)); });
            });
        })();
    </script>
}