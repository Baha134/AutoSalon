@model AutoSalon.ViewModels.CarListViewModel
@{
    ViewData["Title"] = "Каталог автомобилей";
    ViewData["Description"] = "Каталог автомобилей. " + Model.TotalCount + " авто в наличии.";
}

<div class="container mt-4">

    <!-- Мобильная кнопка фильтров -->
    <button class="filters-drawer-btn d-lg-none mb-3 btn btn-outline-secondary w-100" id="drawer-open-btn">
        🔍 Фильтры
    </button>

    <!-- Поиск -->
    <form method="get" action="/catalog" class="d-flex gap-2 mb-4">
        <input type="text" name="Search" value="@Model.Filter.Search" class="form-control" placeholder="Поиск по марке или модели..." autocomplete="off" />
        <button type="submit" class="btn btn-primary px-4">Найти</button>
        @if (Model.Filter.HasActiveFilters)
        {
            <a href="/catalog" class="btn btn-outline-secondary">Сбросить</a>
        }
    </form>

    <div class="catalog-wrap">
        <!-- Фильтры (sidebar) -->
        <form method="get" action="/catalog" class="filters-sidebar d-none d-lg-block">
            <div class="filter-group">
                <div class="filter-label">Марка</div>
                <select name="Brand" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">Все марки</option>
                    @foreach (var b in Model.Brands)
                    {
                        <option value="@b" selected="@(Model.Filter.Brand == b ? "selected" : null)">@b</option>
                    }
                </select>
            </div>
            <div class="filter-group">
                <div class="filter-label">Цена, ₸</div>
                <div class="filter-row">
                    <input type="number" name="PriceMin" value="@Model.Filter.PriceMin" placeholder="от" class="form-control form-control-sm" />
                    <input type="number" name="PriceMax" value="@Model.Filter.PriceMax" placeholder="до" class="form-control form-control-sm" />
                </div>
            </div>
            <div class="filter-group">
                <div class="filter-label">Год выпуска</div>
                <div class="filter-row">
                    <input type="number" name="YearMin" value="@Model.Filter.YearMin" placeholder="от" class="form-control form-control-sm" min="1990" max="@DateTime.Now.Year" />
                    <input type="number" name="YearMax" value="@Model.Filter.YearMax" placeholder="до" class="form-control form-control-sm" min="1990" max="@DateTime.Now.Year" />
                </div>
            </div>
            <div class="filter-group">
                <div class="filter-label">Кузов</div>
                <select name="BodyType" class="form-select form-select-sm">
                    <option value="">Все</option>
                    @if (Model.BodyTypes != null)
                    {
                        foreach (var bt in Model.BodyTypes)
                        {
                            <option value="@bt" selected="@(Model.Filter.BodyType == bt ? "selected" : null)">@bt</option>
                        }
                    }
                </select>
            </div>
            <div class="filter-group">
                <div class="filter-label">Коробка</div>
                <select name="Transmission" class="form-select form-select-sm">
                    <option value="">Все</option>
                    <option value="Автомат" selected="@(Model.Filter.Transmission == "Автомат" ? "selected" : null)">Автомат</option>
                    <option value="Механика" selected="@(Model.Filter.Transmission == "Механика" ? "selected" : null)">Механика</option>
                    <option value="Вариатор" selected="@(Model.Filter.Transmission == "Вариатор" ? "selected" : null)">Вариатор</option>
                    <option value="Робот" selected="@(Model.Filter.Transmission == "Робот" ? "selected" : null)">Робот</option>
                </select>
            </div>
            <div class="filter-group">
                <div class="filter-label">Топливо</div>
                <select name="FuelType" class="form-select form-select-sm">
                    <option value="">Все</option>
                    <option value="Бензин" selected="@(Model.Filter.FuelType == "Бензин" ? "selected" : null)">Бензин</option>
                    <option value="Дизель" selected="@(Model.Filter.FuelType == "Дизель" ? "selected" : null)">Дизель</option>
                    <option value="Гибрид" selected="@(Model.Filter.FuelType == "Гибрид" ? "selected" : null)">Гибрид</option>
                    <option value="Электро" selected="@(Model.Filter.FuelType == "Электро" ? "selected" : null)">Электро</option>
                </select>
            </div>
            <input type="hidden" name="Page" value="1" />
            <button type="submit" class="filter-apply">Применить</button>
            @if (Model.Filter.HasActiveFilters)
            {
                <a href="/catalog" class="filter-reset d-block text-center mt-2">Сбросить фильтры</a>
            }
        </form>

        <!-- Каталог -->
        <div>
            <div class="catalog-header">
                <div class="catalog-total">
                    @Model.TotalCount авто
                    @if (!string.IsNullOrEmpty(Model.Filter.Search))
                    {
                        <span>по запросу «@Model.Filter.Search»</span>
                    }
                </div>
                <div class="catalog-sort">
                    <form method="get" action="/catalog" id="sort-form">
                        @if (!string.IsNullOrEmpty(Model.Filter.Brand))
                        {
                            <input type="hidden" name="Brand" value="@Model.Filter.Brand" />
                        }
                        @if (!string.IsNullOrEmpty(Model.Filter.BodyType))
                        {
                            <input type="hidden" name="BodyType" value="@Model.Filter.BodyType" />
                        }
                        @if (!string.IsNullOrEmpty(Model.Filter.Transmission))
                        {
                            <input type="hidden" name="Transmission" value="@Model.Filter.Transmission" />
                        }
                        @if (!string.IsNullOrEmpty(Model.Filter.FuelType))
                        {
                            <input type="hidden" name="FuelType" value="@Model.Filter.FuelType" />
                        }
                        @if (!string.IsNullOrEmpty(Model.Filter.Search))
                        {
                            <input type="hidden" name="Search" value="@Model.Filter.Search" />
                        }
                        @if (Model.Filter.PriceMin.HasValue)
                        {
                            <input type="hidden" name="PriceMin" value="@Model.Filter.PriceMin" />
                        }
                        @if (Model.Filter.PriceMax.HasValue)
                        {
                            <input type="hidden" name="PriceMax" value="@Model.Filter.PriceMax" />
                        }
                        @if (Model.Filter.YearMin.HasValue)
                        {
                            <input type="hidden" name="YearMin" value="@Model.Filter.YearMin" />
                        }
                        @if (Model.Filter.YearMax.HasValue)
                        {
                            <input type="hidden" name="YearMax" value="@Model.Filter.YearMax" />
                        }
                        <select name="Sort" class="form-select form-select-sm" style="width:auto" onchange="document.getElementById('sort-form').submit()">
                            <option value="new" selected="@(Model.Filter.Sort == "new" ? "selected" : null)">Сначала новые</option>
                            <option value="price_asc" selected="@(Model.Filter.Sort == "price_asc" ? "selected" : null)">Цена ↑</option>
                            <option value="price_desc" selected="@(Model.Filter.Sort == "price_desc" ? "selected" : null)">Цена ↓</option>
                            <option value="popular" selected="@(Model.Filter.Sort == "popular" ? "selected" : null)">Популярные</option>
                        </select>
                    </form>
                </div>
            </div>

            @if (Model.Cars.Any())
            {
                <div class="car-grid" id="catalog-grid">
                    @foreach (var car in Model.Cars)
                    {
                        <partial name="_CarCard" model="car" />
                    }
                </div>

                <!-- Пагинация -->
                @if (Model.TotalPages > 1)
                {
                    <nav class="mt-4">
                        <ul class="pagination justify-content-center">
                            @for (var p = 1; p <= Model.TotalPages; p++)
                            {
                                var isActive = p == Model.Filter.Page;
                                <li class="page-item @(isActive ? "active" : "")">
                                    @if (isActive)
                                    {
                                        <span class="page-link">@p</span>
                                    }
                                    else
                                    {
                                        <a class="page-link" href="/catalog?Page=@p">@p</a>
                                    }
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="empty-state py-5">
                    <div class="empty-icon">🚗</div>
                    <h3>Ничего не нашлось</h3>
                    @if (Model.Filter.HasActiveFilters)
                    {
                        <p>Попробуйте изменить параметры фильтра</p>
                        <a href="/catalog" class="btn btn-primary">Сбросить фильтры</a>
                    }
                    else
                    {
                        <p>Скоро здесь появятся новые автомобили</p>
                    }
                    <a href="#" class="btn btn-outline-secondary mt-2" onclick="document.getElementById('lead-anchor') && document.getElementById('lead-anchor').scrollIntoView({behavior:'smooth'})">Оставить заявку</a>
                </div>
            }
        </div>
    </div>
</div>

<!-- Мобильный Drawer-фильтр -->
<div class="filters-drawer" id="filters-drawer">
    <div class="drawer-backdrop" id="drawer-backdrop"></div>
    <div class="drawer-panel">
        <div class="drawer-handle"></div>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <strong>Фильтры</strong>
            <button class="btn btn-sm btn-outline-secondary" id="drawer-close-btn">✕</button>
        </div>
        <form method="get" action="/catalog">
            <div class="mb-3">
                <label class="form-label small text-muted">Марка</label>
                <select name="Brand" class="form-select form-select-sm">
                    <option value="">Все марки</option>
                    @foreach (var b in Model.Brands)
                    {
                        <option value="@b" selected="@(Model.Filter.Brand == b ? "selected" : null)">@b</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label small text-muted">Цена от</label>
                <input type="number" name="PriceMin" value="@Model.Filter.PriceMin" class="form-control form-control-sm" placeholder="от ₸" />
            </div>
            <div class="mb-3">
                <label class="form-label small text-muted">Цена до</label>
                <input type="number" name="PriceMax" value="@Model.Filter.PriceMax" class="form-control form-control-sm" placeholder="до ₸" />
            </div>
            <button type="submit" class="btn btn-primary w-100">Применить</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Мобильный drawer CSS (inline для drawer, т.к. не отображается в CSS desktop)
        document.addEventListener('DOMContentLoaded', function() {
            const drawerStyles = `
                .filters-drawer { position:fixed;inset:0;z-index:1050;pointer-events:none; }
                .filters-drawer.open { pointer-events:auto; }
                .drawer-backdrop { position:absolute;inset:0;background:rgba(0,0,0,.5);opacity:0;transition:opacity .3s; }
                .filters-drawer.open .drawer-backdrop { opacity:1; }
                .drawer-panel { position:absolute;bottom:0;left:0;right:0;background:#fff;border-radius:16px 16px 0 0;padding:20px;transform:translateY(100%);transition:transform .3s; max-height:85vh;overflow-y:auto; }
                .drawer-handle { width:40px;height:4px;background:#ddd;border-radius:2px;margin:0 auto 16px; }
                .filters-drawer.open .drawer-panel { transform:translateY(0); }
                       @@media(min-width:992px){ .filters-drawer-btn { display:none!important; } .filters-drawer { display:none!important; } }
                        @@media(max-width:991px){ .filters-sidebar { display:none!important; } .filters-drawer { display:block!important; } .catalog-wrap { grid-template-columns:1fr!important; } }
            `;
            const style = document.createElement('style');
            style.textContent = drawerStyles;
            document.head.appendChild(style);
        });
    </script>
}
