@model AutoSalon.ViewModels.CarListViewModel

@functions {
    string PageUrl(AutoSalon.ViewModels.CarFilterViewModel f, int page)
    {
        var parts = new System.Collections.Generic.List<string>();
        parts.Add("Page=" + page);
        if (!string.IsNullOrEmpty(f.Brand)) parts.Add("Brand=" + Uri.EscapeDataString(f.Brand));
        if (!string.IsNullOrEmpty(f.BodyType)) parts.Add("BodyType=" + Uri.EscapeDataString(f.BodyType));
        if (!string.IsNullOrEmpty(f.Transmission)) parts.Add("Transmission=" + Uri.EscapeDataString(f.Transmission));
        if (!string.IsNullOrEmpty(f.FuelType)) parts.Add("FuelType=" + Uri.EscapeDataString(f.FuelType));
        if (!string.IsNullOrEmpty(f.Search)) parts.Add("Search=" + Uri.EscapeDataString(f.Search));
        if (!string.IsNullOrEmpty(f.Sort)) parts.Add("Sort=" + Uri.EscapeDataString(f.Sort!));
        if (f.PriceMin.HasValue) parts.Add("PriceMin=" + f.PriceMin.Value);
        if (f.PriceMax.HasValue) parts.Add("PriceMax=" + f.PriceMax.Value);
        if (f.YearMin.HasValue) parts.Add("YearMin=" + f.YearMin.Value);
        if (f.YearMax.HasValue) parts.Add("YearMax=" + f.YearMax.Value);
        if (f.MileageMax.HasValue) parts.Add("MileageMax=" + f.MileageMax.Value);
        return "/catalog?" + string.Join("&", parts);
    }
}

@{
    ViewData["Title"] = L["Catalog_Title"];
    ViewData["Description"] = L["Catalog_Title"] + ". " + Model.TotalCount + " авто.";
}

<div class="container mt-4">

    <button class="filters-drawer-btn d-lg-none mb-3 btn btn-outline-secondary w-100" id="drawer-open-btn">
        @L["Catalog_Filters"]
    </button>

    <form method="get" action="/catalog" class="d-flex gap-2 mb-4">
        <input type="text" name="Search" value="@Model.Filter.Search"
               class="form-control" placeholder="@L["Catalog_Search_Placeholder"]"
               autocomplete="off" maxlength="100" />
        <button type="submit" class="btn btn-primary px-4">@L["Catalog_Search_Button"]</button>
        @if (Model.Filter.HasActiveFilters)
        {
            <a href="/catalog" class="btn btn-outline-secondary">@L["Catalog_Reset"]</a>
        }
    </form>

    <div class="catalog-wrap">

        <!-- Sidebar фильтры -->
        <form method="get" action="/catalog" class="filters-sidebar d-none d-lg-block">
            <div class="filter-group">
                <div class="filter-label">@L["Catalog_Brand"]</div>
                <select name="Brand" class="form-select form-select-sm" onchange="this.form.submit()">
                    <option value="">@L["Catalog_AllBrands"]</option>
                    @foreach (var b in Model.Brands)
                    {
                        <option value="@b" selected="@(Model.Filter.Brand == b ? "selected" : null)">@b</option>
                    }
                </select>
            </div>

            <div class="filter-group">
                <div class="filter-label">@L["Catalog_Price"]</div>
                <div class="filter-row">
                    <input type="number" name="PriceMin" value="@Model.Filter.PriceMin"
                           placeholder="@L["Catalog_From"]" class="form-control form-control-sm" min="0" />
                    <input type="number" name="PriceMax" value="@Model.Filter.PriceMax"
                           placeholder="@L["Catalog_To"]" class="form-control form-control-sm" min="0" />
                </div>
            </div>

            <div class="filter-group">
                <div class="filter-label">@L["Catalog_Year"]</div>
                <div class="filter-row">
                    <input type="number" name="YearMin" value="@Model.Filter.YearMin"
                           placeholder="@L["Catalog_From"]" class="form-control form-control-sm"
                           min="1990" max="@DateTime.Now.Year" />
                    <input type="number" name="YearMax" value="@Model.Filter.YearMax"
                           placeholder="@L["Catalog_To"]" class="form-control form-control-sm"
                           min="1990" max="@DateTime.Now.Year" />
                </div>
            </div>

            <div class="filter-group">
                <div class="filter-label">@L["Catalog_Body"]</div>
                <select name="BodyType" class="form-select form-select-sm">
                    <option value="">@L["Catalog_All"]</option>
                    @if (Model.BodyTypes != null)
                    {
                        foreach (var bt in Model.BodyTypes)
                        {
                            <option value="@bt" selected="@(Model.Filter.BodyType == bt ? "selected" : null)">@bt</option>
                        }
                    }
                </select>
            </div>

            <div class="filter-group">
                <div class="filter-label">@L["Catalog_Transmission"]</div>
                <select name="Transmission" class="form-select form-select-sm">
                    <option value="">@L["Catalog_All"]</option>
                    <option value="Автомат" selected="@(Model.Filter.Transmission == "Автомат" ? "selected" : null)">Автомат</option>
                    <option value="Механика" selected="@(Model.Filter.Transmission == "Механика" ? "selected" : null)">Механика</option>
                    <option value="Вариатор" selected="@(Model.Filter.Transmission == "Вариатор" ? "selected" : null)">Вариатор</option>
                    <option value="Робот" selected="@(Model.Filter.Transmission == "Робот" ? "selected" : null)">Робот</option>
                </select>
            </div>

            <div class="filter-group">
                <div class="filter-label">@L["Catalog_Fuel"]</div>
                <select name="FuelType" class="form-select form-select-sm">
                    <option value="">@L["Catalog_All"]</option>
                    <option value="Бензин" selected="@(Model.Filter.FuelType == "Бензин" ? "selected" : null)">Бензин</option>
                    <option value="Дизель" selected="@(Model.Filter.FuelType == "Дизель" ? "selected" : null)">Дизель</option>
                    <option value="Гибрид" selected="@(Model.Filter.FuelType == "Гибрид" ? "selected" : null)">Гибрид</option>
                    <option value="Электро" selected="@(Model.Filter.FuelType == "Электро" ? "selected" : null)">Электро</option>
                </select>
            </div>

            <input type="hidden" name="Page" value="1" />
            <button type="submit" class="filter-apply">@L["Catalog_Apply"]</button>
            @if (Model.Filter.HasActiveFilters)
            {
                <a href="/catalog" class="filter-reset d-block text-center mt-2">@L["Catalog_ResetFilters"]</a>
            }
        </form>

        <!-- Каталог -->
        <div class="catalog-main">
            <div class="catalog-header">
                <div class="catalog-total">
                    @Model.TotalCount авто
                    @if (!string.IsNullOrEmpty(Model.Filter.Search))
                    {
                        <span class="text-muted">по запросу «@Model.Filter.Search»</span>
                    }
                </div>

                <div class="catalog-sort">
                    <form method="get" action="/catalog" id="sort-form">
                        @if (!string.IsNullOrEmpty(Model.Filter.Brand))
                        {
                            <input type="hidden" name="Brand" value="@Model.Filter.Brand" />
                        }
                        @if (!string.IsNullOrEmpty(Model.Filter.BodyType))
                        {
                            <input type="hidden" name="BodyType" value="@Model.Filter.BodyType" />
                        }
                        @if (!string.IsNullOrEmpty(Model.Filter.Transmission))
                        {
                            <input type="hidden" name="Transmission" value="@Model.Filter.Transmission" />
                        }
                        @if (!string.IsNullOrEmpty(Model.Filter.FuelType))
                        {
                            <input type="hidden" name="FuelType" value="@Model.Filter.FuelType" />
                        }
                        @if (!string.IsNullOrEmpty(Model.Filter.Search))
                        {
                            <input type="hidden" name="Search" value="@Model.Filter.Search" />
                        }
                        @if (Model.Filter.PriceMin.HasValue)
                        {
                            <input type="hidden" name="PriceMin" value="@Model.Filter.PriceMin" />
                        }
                        @if (Model.Filter.PriceMax.HasValue)
                        {
                            <input type="hidden" name="PriceMax" value="@Model.Filter.PriceMax" />
                        }
                        @if (Model.Filter.YearMin.HasValue)
                        {
                            <input type="hidden" name="YearMin" value="@Model.Filter.YearMin" />
                        }
                        @if (Model.Filter.YearMax.HasValue)
                        {
                            <input type="hidden" name="YearMax" value="@Model.Filter.YearMax" />
                        }

                        <select name="Sort" class="form-select form-select-sm" style="width:auto"
                                onchange="document.getElementById('sort-form').submit()">
                            <option value="new" selected="@(Model.Filter.Sort == "new" ? "selected" : null)">@L["Catalog_Sort_New"]</option>
                            <option value="price_asc" selected="@(Model.Filter.Sort == "price_asc" ? "selected" : null)">@L["Catalog_Sort_PriceAsc"]</option>
                            <option value="price_desc" selected="@(Model.Filter.Sort == "price_desc" ? "selected" : null)">@L["Catalog_Sort_PriceDesc"]</option>
                            <option value="popular" selected="@(Model.Filter.Sort == "popular" ? "selected" : null)">@L["Catalog_Sort_Popular"]</option>
                        </select>
                    </form>
                </div>
            </div>

            @if (Model.Cars.Any())
            {
                <div class="car-grid" id="catalog-grid">
                    @foreach (var car in Model.Cars)
                    {
                        <partial name="_CarCard" model="car" />
                    }
                </div>

                @if (Model.TotalPages > 1)
                {
                    <nav class="mt-4" aria-label="Страницы каталога">
                        <ul class="pagination justify-content-center flex-wrap">
                            @if (Model.Filter.Page > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@PageUrl(Model.Filter, Model.Filter.Page - 1)">←</a>
                                </li>
                            }
                            @for (var p = 1; p <= Model.TotalPages; p++)
                            {
                                var isActive = p == Model.Filter.Page;
                                <li class="page-item @(isActive ? "active" : "")">
                                    @if (isActive)
                                    {
                                        <span class="page-link">@p</span>
                                    }
                                    else
                                    {

                                        <a class="page-link" href="@PageUrl(Model.Filter, p)">@p</a>
                                    }
                                </li>
                            }
                            @if (Model.Filter.Page < Model.TotalPages)
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@PageUrl(Model.Filter, Model.Filter.Page + 1)">→</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="empty-state py-5">
                    <div class="empty-icon">🚗</div>
                    <h3>@L["Catalog_Empty"]</h3>
                    @if (Model.Filter.HasActiveFilters)
                    {
                        <p>@L["Catalog_Empty_Filter"]</p>
                        <a href="/catalog" class="btn btn-primary mt-2">@L["Catalog_ResetFilters"]</a>
                    }
                    else
                    {
                        <p>@L["Catalog_Empty_Soon"]</p>
                    }
                    <a href="#lead-anchor" class="btn btn-outline-secondary mt-2">@L["Catalog_LeaveRequest"]</a>
                </div>
            }
        </div>
    </div>
</div>

<!-- Мобильный Drawer -->
<div class="filters-drawer" id="filters-drawer">
    <div class="drawer-backdrop" id="drawer-backdrop"></div>
    <div class="drawer-panel">
        <div class="drawer-handle"></div>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <strong>@L["Catalog_Filters"]</strong>
            <button type="button" class="btn btn-sm btn-outline-secondary" id="drawer-close-btn">✕</button>
        </div>
        <form method="get" action="/catalog">
            <div class="mb-3">
                <label class="form-label small text-muted">@L["Catalog_Brand"]</label>
                <select name="Brand" class="form-select form-select-sm">
                    <option value="">@L["Catalog_AllBrands"]</option>
                    @foreach (var b in Model.Brands)
                    {
                        <option value="@b" selected="@(Model.Filter.Brand == b ? "selected" : null)">@b</option>
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label small text-muted">@L["Catalog_PriceFrom"]</label>
                <input type="number" name="PriceMin" value="@Model.Filter.PriceMin"
                       class="form-control form-control-sm" placeholder="@L["Catalog_From"]" min="0" />
            </div>
            <div class="mb-3">
                <label class="form-label small text-muted">@L["Catalog_PriceTo"]</label>
                <input type="number" name="PriceMax" value="@Model.Filter.PriceMax"
                       class="form-control form-control-sm" placeholder="@L["Catalog_To"]" min="0" />
            </div>
            <div class="mb-3">
                <label class="form-label small text-muted">@L["Catalog_Body"]</label>
                <select name="BodyType" class="form-select form-select-sm">
                    <option value="">@L["Catalog_All"]</option>
                    <option value="Седан" selected="@(Model.Filter.BodyType == "Седан" ? "selected" : null)">Седан</option>
                    <option value="Кроссовер" selected="@(Model.Filter.BodyType == "Кроссовер" ? "selected" : null)">Кроссовер</option>
                    <option value="Внедорожник" selected="@(Model.Filter.BodyType == "Внедорожник" ? "selected" : null)">Внедорожник</option>
                    <option value="Хэтчбек" selected="@(Model.Filter.BodyType == "Хэтчбек" ? "selected" : null)">Хэтчбек</option>
                    <option value="Минивэн" selected="@(Model.Filter.BodyType == "Минивэн" ? "selected" : null)">Минивэн</option>
                    <option value="Купе" selected="@(Model.Filter.BodyType == "Купе" ? "selected" : null)">Купе</option>
                    <option value="Пикап" selected="@(Model.Filter.BodyType == "Пикап" ? "selected" : null)">Пикап</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label small text-muted">@L["Catalog_Transmission"]</label>
                <select name="Transmission" class="form-select form-select-sm">
                    <option value="">@L["Catalog_All"]</option>
                    <option value="Автомат" selected="@(Model.Filter.Transmission == "Автомат" ? "selected" : null)">Автомат</option>
                    <option value="Механика" selected="@(Model.Filter.Transmission == "Механика" ? "selected" : null)">Механика</option>
                    <option value="Вариатор" selected="@(Model.Filter.Transmission == "Вариатор" ? "selected" : null)">Вариатор</option>
                    <option value="Робот" selected="@(Model.Filter.Transmission == "Робот" ? "selected" : null)">Робот</option>
                </select>
            </div>
            <input type="hidden" name="Page" value="1" />
            <button type="submit" class="btn btn-primary w-100">@L["Catalog_Apply"]</button>
            @if (Model.Filter.HasActiveFilters)
            {
                <a href="/catalog" class="btn btn-outline-secondary w-100 mt-2">@L["Catalog_Reset"]</a>
            }
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var openBtn = document.getElementById('drawer-open-btn');
            var closeBtn = document.getElementById('drawer-close-btn');
            var backdrop = document.getElementById('drawer-backdrop');
            var drawer = document.getElementById('filters-drawer');
            function open() { drawer.classList.add('open'); document.body.style.overflow = 'hidden'; }
            function close() { drawer.classList.remove('open'); document.body.style.overflow = ''; }
            if (openBtn) openBtn.addEventListener('click', open);
            if (closeBtn) closeBtn.addEventListener('click', close);
            if (backdrop) backdrop.addEventListener('click', close);
        })();
    </script>
}