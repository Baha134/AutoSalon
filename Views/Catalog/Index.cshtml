@if (Model.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (var p = 1; p <= Model.TotalPages; p++)
            {
                var isActive = p == Model.Filter.Page;

                @* Собираем строку параметров, сохраняя все фильтры *@
                var qp = new System.Collections.Generic.Dictionary<string, string>
                {
                    ["Page"] = p.ToString()
                };
                if (!string.IsNullOrEmpty(Model.Filter.Brand)) qp["Brand"] = Model.Filter.Brand;
                if (!string.IsNullOrEmpty(Model.Filter.BodyType)) qp["BodyType"] = Model.Filter.BodyType;
                if (!string.IsNullOrEmpty(Model.Filter.Transmission)) qp["Transmission"] = Model.Filter.Transmission;
                if (!string.IsNullOrEmpty(Model.Filter.FuelType)) qp["FuelType"] = Model.Filter.FuelType;
                if (!string.IsNullOrEmpty(Model.Filter.Search)) qp["Search"] = Model.Filter.Search;
                if (!string.IsNullOrEmpty(Model.Filter.Sort)) qp["Sort"] = Model.Filter.Sort!;
                if (Model.Filter.PriceMin.HasValue) qp["PriceMin"] = Model.Filter.PriceMin.Value.ToString();
                if (Model.Filter.PriceMax.HasValue) qp["PriceMax"] = Model.Filter.PriceMax.Value.ToString();
                if (Model.Filter.YearMin.HasValue) qp["YearMin"] = Model.Filter.YearMin.Value.ToString();
                if (Model.Filter.YearMax.HasValue) qp["YearMax"] = Model.Filter.YearMax.Value.ToString();
                if (Model.Filter.MileageMax.HasValue) qp["MileageMax"] = Model.Filter.MileageMax.Value.ToString();

                var qs = string.Join("&", qp.Select(x =>
                    $"{Uri.EscapeDataString(x.Key)}={Uri.EscapeDataString(x.Value)}"));

                <li class="page-item @(isActive ? "active" : "")">
                    @if (isActive)
                    {
                        <span class="page-link">@p</span>
                    }
                    else
                    {
                        <a class="page-link" href="/catalog?@qs">@p</a>
                    }
                </li>
            }
        </ul>
    </nav>
}