@model AutoSalon.ViewModels.CompareViewModel
@{
    ViewData["Title"] = "Сравнение автомобилей";
    var cars = Model.Cars;
}

<div class="container mt-4">
    <h1 class="h3 fw-bold mb-4">Сравнение автомобилей</h1>

    @if (!cars.Any())
    {
        <div class="empty-state py-5 text-center">
            <div class="empty-icon">⚖️</div>
            <h3>Список сравнения пуст</h3>
            <p>Добавьте до 3 автомобилей для сравнения</p>
            <a href="/catalog" class="btn btn-primary">Перейти в каталог</a>
        </div>
    }
    else
    {
        @* Заголовки с фото *@
        <div class="table-responsive">
            <table class="table table-bordered align-middle compare-table">
                <thead>
                    <tr>
                        <th style="width:180px">Характеристика</th>
                        @foreach (var car in cars)
                        {
                            <th class="text-center">
                                @if (car.MainPhoto != null)
                                {
                                    <img src="@car.MainPhoto.FilePath"
                                         alt="@car.Brand @car.Model"
                                         style="width:100%;height:120px;object-fit:cover;border-radius:8px;margin-bottom:8px"
                                         loading="lazy" />
                                }
                                <div class="fw-bold">@car.Brand @car.Model</div>
                                <div class="fw-bold text-primary">@car.DisplayPrice</div>
                                <div class="mt-2 d-flex flex-column gap-1">
                                    <a href="/car/@car.Slug" class="btn btn-sm btn-primary">Подробнее</a>
                                    <form method="post" action="/compare/remove/@car.Id">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-secondary w-100">Убрать</button>
                                    </form>
                                </div>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @{
                        // Вычисляем лучшие значения заранее
                        var minPrice = cars.Min(c => c.Price);
                        var minMileage = cars.Min(c => c.Mileage);
                        var maxYear = cars.Max(c => c.Year);
                    }

                    @* Цена — зелёным самую низкую *@
                    <tr>
                        <td class="text-muted small fw-semibold">Цена</td>
                        @foreach (var car in cars)
                        {
                            <td class="text-center @(car.Price == minPrice ? "table-success" : "")">
                                @car.DisplayPrice
                            </td>
                        }
                    </tr>

                    @* Год — зелёным самый новый *@
                    <tr>
                        <td class="text-muted small fw-semibold">Год</td>
                        @foreach (var car in cars)
                        {
                            <td class="text-center @(car.Year == maxYear ? "table-success" : "")">
                                @car.Year
                            </td>
                        }
                    </tr>

                    @* Пробег — зелёным самый маленький *@
                    <tr>
                        <td class="text-muted small fw-semibold">Пробег</td>
                        @foreach (var car in cars)
                        {
                            <td class="text-center @(car.Mileage == minMileage ? "table-success" : "")">
                                @car.DisplayMileage
                            </td>
                        }
                    </tr>

                    @* Остальные строки — без подсветки *@
                    @{
                        var plainRows = new[]
                        {
                            ("Двигатель", cars.Select(c => $"{c.EngineVolume} л").ToArray()),
                            ("Топливо",   cars.Select(c => c.FuelType).ToArray()),
                            ("Коробка",   cars.Select(c => c.Transmission).ToArray()),
                            ("Привод",    cars.Select(c => c.DriveType).ToArray()),
                            ("Кузов",     cars.Select(c => c.BodyType).ToArray()),
                            ("Цвет",      cars.Select(c => c.Color).ToArray()),
                            ("Город",     cars.Select(c => c.City).ToArray()),
                        };
                    }
                    @foreach (var (label, values) in plainRows)
                    {
                        <tr>
                            <td class="text-muted small fw-semibold">@label</td>
                            @for (var i = 0; i < cars.Count; i++)
                            {
                                <td class="text-center">@(i < values.Length ? values[i] : "—")</td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (cars.Count < 3)
        {
            <div class="alert alert-info mt-3">
                Можно добавить ещё @(3 - cars.Count) авто для сравнения.
                <a href="/catalog" class="alert-link">Перейти в каталог</a>
            </div>
        }

        <div class="mt-3">
            <form method="post" action="/compare/clear">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger btn-sm">🗑 Очистить список</button>
            </form>
        </div>
    }
</div>
