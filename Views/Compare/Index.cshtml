@model AutoSalon.ViewModels.CompareViewModel

@{
    ViewData["Title"] = L["Compare_Title"];
    var cars = Model.Cars;
}

<div class="container mt-4">
    <h1 class="h3 fw-bold mb-4">@L["Compare_Title"]</h1>

    @if (!cars.Any())
    {
        <div class="empty-state py-5 text-center">
            <div class="empty-icon">⚖️</div>
            <h3>@L["Compare_Empty"]</h3>
            <p>@L["Compare_Empty_Sub"]</p>
            <a href="/catalog" class="btn btn-primary">@L["Compare_ToCatalog"]</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-bordered align-middle compare-table">
                <thead>
                    <tr>
                        <th style="width:180px">@L["Compare_Spec"]</th>
                        @foreach (var car in cars)
                        {
                            <th class="text-center">
                                @if (car.MainPhoto != null)
                                {
                                    <img src="@car.MainPhoto.FilePath"
                                         alt="@car.Brand @car.Model"
                                         style="width:100%;height:120px;object-fit:cover;border-radius:8px;margin-bottom:8px"
                                         loading="lazy" />
                                }
                                <div class="fw-bold">@car.Brand @car.Model</div>
                                <div class="fw-bold text-primary">@car.DisplayPrice</div>
                                <div class="mt-2 d-flex flex-column gap-1">
                                    <a href="/car/@car.Slug" class="btn btn-sm btn-primary">@L["Compare_Details"]</a>
                                    <form method="post" action="/compare/remove/@car.Id">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-secondary w-100">@L["Compare_Remove"]</button>
                                    </form>
                                </div>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @{
                        var minPrice = cars.Min(c => c.Price);
                        var minMileage = cars.Min(c => c.Mileage);
                        var maxYear = cars.Max(c => c.Year);
                    }

                    <tr>
                        <td class="text-muted small fw-semibold">@L["Compare_Price"]</td>
                        @foreach (var car in cars)
                        {
                            <td class="text-center @(car.Price == minPrice ? "table-success" : "")">@car.DisplayPrice</td>
                        }
                    </tr>

                    <tr>
                        <td class="text-muted small fw-semibold">@L["Compare_Year"]</td>
                        @foreach (var car in cars)
                        {
                            <td class="text-center @(car.Year == maxYear ? "table-success" : "")">@car.Year</td>
                        }
                    </tr>

                    <tr>
                        <td class="text-muted small fw-semibold">@L["Compare_Mileage"]</td>
                        @foreach (var car in cars)
                        {
                            <td class="text-center @(car.Mileage == minMileage ? "table-success" : "")">@car.DisplayMileage</td>
                        }
                    </tr>

                    @{
                        var plainRows = new[]
                        {
                            (L["Compare_Engine"].Value, cars.Select(c => $"{c.EngineVolume} л").ToArray()),
                            (L["Compare_Fuel"].Value,   cars.Select(c => c.FuelType).ToArray()),
                            (L["Compare_Transmission"].Value, cars.Select(c => c.Transmission).ToArray()),
                            (L["Compare_Drive"].Value,  cars.Select(c => c.DriveType).ToArray()),
                            (L["Compare_Body"].Value,   cars.Select(c => c.BodyType).ToArray()),
                            (L["Compare_Color"].Value,  cars.Select(c => c.Color).ToArray()),
                            (L["Compare_City"].Value,   cars.Select(c => c.City).ToArray()),
                        };
                    }

                    @foreach (var (label, values) in plainRows)
                    {
                        <tr>
                            <td class="text-muted small fw-semibold">@label</td>
                            @for (var i = 0; i < cars.Count; i++)
                            {
                                <td class="text-center">@(i < values.Length ? values[i] : "—")</td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (cars.Count < 3)
        {
            <div class="alert alert-info mt-3">
                @string.Format(L["Compare_CanAdd"], 3 - cars.Count)
                <a href="/catalog" class="alert-link">@L["Compare_ToCatalog"]</a>
            </div>
        }

        <div class="mt-3">
            <form method="post" action="/compare/clear">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger btn-sm">@L["Compare_Clear"]</button>
            </form>
        </div>
    }
</div>