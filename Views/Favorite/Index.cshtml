@model AutoSalon.ViewModels.FavoriteViewModel
@{
    ViewData["Title"] = "Избранное";
}

<div class="container mt-4">
    <h1 class="h3 fw-bold mb-4">Избранное</h1>

    @if (!Model.Cars.Any())
    {
        <div class="empty-state py-5 text-center">
            <div class="empty-icon">❤️</div>
            <h3>Список избранного пуст</h3>
            <p>Нажмите ♡ на карточке автомобиля, чтобы сохранить</p>
            <a href="/catalog" class="btn btn-primary">Перейти в каталог</a>
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="text-muted">@Model.Cars.Count авто в избранном</div>
        </div>
        <div class="car-grid">
            @foreach (var car in Model.Cars)
            {
                <partial name="_CarCard" model="car" />
            }
        </div>
    }
</div>
