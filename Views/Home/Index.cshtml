@model AutoSalon.ViewModels.HomeViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(Model.Settings?.SalonName ?? "Автопрайм") — Премиальный автосалон</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@700;900&family=Manrope:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --gold: #F5A623;
            --gold-dark: #D4861A;
            --dark: #0d0d0d;
            --dark2: #141414;
            --dark3: #1c1c1c;
            --text: #ffffff;
            --muted: rgba(255,255,255,0.6);
            --radius: 14px;
        }

        html { scroll-behavior: smooth; }
        body {
            font-family: 'Manrope', sans-serif;
            background: var(--dark);
            color: var(--text);
            overflow-x: hidden;
        }

        /* ── NAVBAR ── */
        .nav {
            position: fixed; top: 0; left: 0; right: 0; z-index: 100;
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 48px; height: 72px;
            background: rgba(13,13,13,0.85);
            backdrop-filter: blur(14px);
            border-bottom: 1px solid rgba(255,255,255,0.06);
            animation: slideDown .5s ease both;
        }
        @@keyframes slideDown { from { transform: translateY(-100%); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

        .nav-logo {
            display: flex; align-items: center; gap: 10px;
            text-decoration: none; color: var(--text);
        }
        .nav-logo-icon {
            width: 38px; height: 38px;
            background: var(--gold); border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 20px;
        }
        .nav-logo-text {
            font-family: 'Unbounded', sans-serif;
            font-size: 16px; font-weight: 700;
        }
        .nav-links { display: flex; gap: 36px; list-style: none; }
        .nav-links a {
            text-decoration: none; color: var(--muted);
            font-size: 14px; font-weight: 500; transition: color .2s;
        }
        .nav-links a:hover, .nav-links a.active { color: var(--gold); }
        .nav-right { display: flex; align-items: center; gap: 24px; }
        .nav-phone {
            color: var(--muted); font-size: 14px;
            text-decoration: none; display: flex; align-items: center; gap: 6px;
        }
        .nav-phone:hover { color: var(--text); }

        .btn-gold {
            background: var(--gold); color: #000;
            font-weight: 700; font-size: 14px;
            padding: 12px 24px; border-radius: 50px;
            border: none; cursor: pointer;
            text-decoration: none;
            transition: background .2s, transform .15s;
            display: inline-flex; align-items: center; gap: 6px;
        }
        .btn-gold:hover { background: var(--gold-dark); transform: translateY(-1px); }
        .btn-gold-lg { font-size: 15px; padding: 14px 32px; }

        .btn-outline {
            background: rgba(255,255,255,0.08);
            backdrop-filter: blur(8px);
            color: var(--text);
            border: 1px solid rgba(255,255,255,0.18);
            padding: 14px 28px; border-radius: 50px;
            font-weight: 600; font-size: 15px;
            cursor: pointer; text-decoration: none;
            transition: background .2s, transform .15s;
        }
        .btn-outline:hover { background: rgba(255,255,255,0.15); transform: translateY(-1px); }

        /* ── HERO ── */
        .hero {
            position: relative; min-height: 100vh;
            display: flex; flex-direction: column;
            justify-content: center; align-items: center;
            text-align: center; padding: 120px 24px 80px;
            overflow: hidden;
        }
        .hero-bg {
            position: absolute; inset: 0; z-index: 0;
            background:
                linear-gradient(to bottom, rgba(13,13,13,0.25) 0%, rgba(13,13,13,0.6) 60%, rgba(13,13,13,1) 100%),
                url('https://images.unsplash.com/photo-1544636331-e26879cd4d9b?w=1600&q=80') center/cover no-repeat;
        }
        .hero-badge {
            position: relative; z-index: 1;
            display: inline-flex; align-items: center; gap: 8px;
            background: rgba(245,166,35,0.15);
            border: 1px solid rgba(245,166,35,0.35);
            border-radius: 50px; padding: 8px 20px;
            font-size: 12px; font-weight: 600; letter-spacing: .1em; text-transform: uppercase;
            color: var(--gold); margin-bottom: 32px;
            animation: fadeUp .6s .2s ease both;
        }
        .hero-title {
            position: relative; z-index: 1;
            font-family: 'Unbounded', sans-serif;
            font-size: clamp(42px, 7vw, 96px);
            font-weight: 900; line-height: 1.05; margin-bottom: 24px;
            animation: fadeUp .6s .35s ease both;
        }
        .hero-title span { color: var(--gold); display: block; }
        .hero-sub {
            position: relative; z-index: 1;
            max-width: 560px; font-size: 17px; line-height: 1.7;
            color: var(--muted); margin-bottom: 48px;
            animation: fadeUp .6s .5s ease both;
        }
        .hero-actions {
            position: relative; z-index: 1;
            display: flex; gap: 16px; flex-wrap: wrap; justify-content: center;
            animation: fadeUp .6s .65s ease both;
        }

        /* ── STATS ── */
        .stats {
            position: relative; z-index: 1;
            display: flex; width: 100%; max-width: 760px; margin-top: 72px;
            animation: fadeUp .6s .8s ease both;
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: var(--radius); overflow: hidden;
            background: rgba(255,255,255,0.03);
            backdrop-filter: blur(8px);
        }
        .stat {
            flex: 1; text-align: center; padding: 28px 16px;
            border-right: 1px solid rgba(255,255,255,0.08);
        }
        .stat:last-child { border-right: none; }
        .stat-num {
            font-family: 'Unbounded', sans-serif;
            font-size: 32px; font-weight: 900;
            color: var(--gold); display: block; margin-bottom: 4px;
        }
        .stat-label { font-size: 13px; color: var(--muted); }

        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(24px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ── SECTIONS ── */
        .section { padding: 96px 48px; }
        .section-label {
            font-size: 12px; font-weight: 700; letter-spacing: .15em;
            text-transform: uppercase; color: var(--gold); margin-bottom: 14px;
        }
        .section-title {
            font-family: 'Unbounded', sans-serif;
            font-size: clamp(26px, 4vw, 40px); font-weight: 900;
            margin-bottom: 48px; line-height: 1.2;
        }

        /* ── CAR CARDS ── */
        .cars-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 24px;
        }
        .car-card {
            background: var(--dark2);
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: var(--radius); overflow: hidden;
            transition: transform .25s, box-shadow .25s, border-color .25s;
            display: flex; flex-direction: column;
        }
        .car-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 24px 48px rgba(0,0,0,0.5);
            border-color: rgba(245,166,35,0.25);
        }
        .car-img-wrap {
            position: relative; aspect-ratio: 16/10; overflow: hidden; background: #1a1a1a;
        }
        .car-img-wrap img {
            width: 100%; height: 100%; object-fit: cover; transition: transform .4s ease;
        }
        .car-card:hover .car-img-wrap img { transform: scale(1.04); }
        .car-img-placeholder {
            width: 100%; height: 100%;
            display: flex; align-items: center; justify-content: center;
            font-size: 48px; color: rgba(255,255,255,0.1);
        }
        .car-badge-pill {
            position: absolute; top: 12px; left: 12px;
            background: var(--gold); color: #000;
            font-size: 11px; font-weight: 700; letter-spacing: .06em;
            padding: 4px 10px; border-radius: 50px;
        }
        .car-badge-sold {
            position: absolute; top: 12px; left: 12px;
            background: rgba(255,255,255,0.15); color: var(--text);
            font-size: 11px; font-weight: 700;
            padding: 4px 10px; border-radius: 50px; backdrop-filter: blur(4px);
        }
        .car-body { padding: 20px; flex: 1; display: flex; flex-direction: column; }
        .car-name { font-family: 'Unbounded', sans-serif; font-size: 16px; font-weight: 700; margin-bottom: 4px; }
        .car-year { font-size: 13px; color: var(--muted); margin-bottom: 14px; }
        .car-price { font-size: 22px; font-weight: 700; color: var(--gold); margin-bottom: 16px; }
        .car-specs { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 20px; flex: 1; }
        .spec { display: flex; align-items: center; gap: 6px; font-size: 13px; color: var(--muted); }
        .car-link {
            display: inline-flex; align-items: center; gap: 6px;
            color: var(--gold); font-weight: 600; font-size: 14px;
            text-decoration: none; transition: gap .2s; margin-top: auto;
        }
        .car-link:hover { gap: 10px; }
        .cars-empty {
            text-align: center; padding: 80px 24px; color: var(--muted); font-size: 16px;
        }
        .cars-empty span { display: block; font-size: 48px; margin-bottom: 16px; }
        .view-all-wrap { text-align: center; margin-top: 48px; }

        /* ── BRANDS ── */
        .brands-section { background: var(--dark2); }
        .brands-grid { display: flex; flex-wrap: wrap; gap: 12px; }
        .brand-pill {
            background: var(--dark3);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 50px; padding: 10px 24px;
            font-size: 14px; font-weight: 600;
            text-decoration: none; color: var(--text);
            transition: border-color .2s, color .2s, transform .15s;
        }
        .brand-pill:hover { border-color: var(--gold); color: var(--gold); transform: translateY(-2px); }

        /* ── WHY US ── */
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 24px;
        }
        .feature {
            background: var(--dark3);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: var(--radius); padding: 28px 24px;
            transition: border-color .2s, transform .2s;
        }
        .feature:hover { border-color: rgba(245,166,35,0.3); transform: translateY(-3px); }
        .feature-icon {
            width: 48px; height: 48px; background: rgba(245,166,35,0.12);
            border-radius: 12px; display: flex; align-items: center; justify-content: center;
            font-size: 22px; margin-bottom: 16px;
        }
        .feature-title { font-family: 'Unbounded', sans-serif; font-size: 14px; font-weight: 700; margin-bottom: 8px; line-height: 1.35; }
        .feature-desc { font-size: 13px; color: var(--muted); line-height: 1.65; }

        /* ── CTA ── */
        .cta-section {
            padding: 96px 48px; text-align: center;
            background: radial-gradient(ellipse 800px 400px at 50% 50%, rgba(245,166,35,0.08) 0%, transparent 70%), var(--dark);
        }
        .cta-section .section-title { margin-bottom: 16px; }
        .cta-section p { color: var(--muted); font-size: 17px; max-width: 520px; margin: 0 auto 40px; line-height: 1.7; }
        .cta-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

        /* ── FOOTER ── */
        .footer { background: #080808; border-top: 1px solid rgba(255,255,255,0.06); padding: 64px 48px 32px; }
        .footer-grid { display: grid; grid-template-columns: 1.8fr 1fr 1fr 1fr; gap: 48px; margin-bottom: 48px; }
        .footer-brand p { color: var(--muted); font-size: 14px; line-height: 1.7; margin-top: 12px; max-width: 240px; }
        .footer-col-title { font-weight: 700; font-size: 12px; letter-spacing: .1em; text-transform: uppercase; margin-bottom: 16px; color: var(--muted); }
        .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
        .footer-col ul li a { text-decoration: none; color: var(--muted); font-size: 14px; transition: color .2s; }
        .footer-col ul li a:hover { color: var(--gold); }
        .footer-contact { display: flex; flex-direction: column; gap: 10px; }
        .footer-contact-item { display: flex; align-items: flex-start; gap: 8px; font-size: 14px; color: var(--muted); }
        .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.06); padding-top: 24px;
            display: flex; justify-content: space-between; align-items: center;
            font-size: 13px; color: rgba(255,255,255,0.3);
        }

        /* ── RESPONSIVE ── */
        @@media (max-width: 900px) { .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; } }
        @@media (max-width: 768px) {
            .nav { padding: 0 20px; }
            .nav-links { display: none; }
            .section { padding: 64px 20px; }
            .footer { padding: 48px 20px 24px; }
            .stats { flex-wrap: wrap; }
            .stat { flex: 0 0 50%; border-right: none; border-bottom: 1px solid rgba(255,255,255,0.08); }
            .stat:nth-child(odd) { border-right: 1px solid rgba(255,255,255,0.08); }
            .footer-bottom { flex-direction: column; gap: 8px; text-align: center; }
            .cta-section { padding: 64px 20px; }
        }
    </style>
</head>
<body>

<!-- ═══ NAVBAR ═══ -->
<nav class="nav">
    <a href="/" class="nav-logo">
        <div class="nav-logo-icon">🚗</div>
        <span class="nav-logo-text">@(Model.Settings?.SalonName ?? "Автопрайм")</span>
    </a>
    <ul class="nav-links">
        <li><a href="/" class="active">Главная</a></li>
        <li><a href="/catalog">Автомобили</a></li>
        <li><a href="/about">О нас</a></li>
    </ul>
    <div class="nav-right">
        @if (!string.IsNullOrEmpty(Model.Settings?.Phone))
        {
            <a href="tel:@Model.Settings.Phone" class="nav-phone">📞 @Model.Settings.Phone</a>
        }
        <a href="/catalog" class="btn-gold">Подобрать авто</a>
    </div>
</nav>

<!-- ═══ HERO ═══ -->
<section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-badge">✦ Премиальный автосалон</div>
    <h1 class="hero-title">
        Найдите автомобиль
        <span>вашей мечты</span>
    </h1>
    <p class="hero-sub">
        Более @Model.TotalCars автомобилей в наличии. Официальная гарантия,
        юридическая чистота, выгодные условия трейд-ин и кредита.
    </p>
    <div class="hero-actions">
        <a href="/catalog" class="btn-gold btn-gold-lg">Посмотреть каталог →</a>
        <a href="/about" class="btn-outline">О салоне</a>
    </div>
    <div class="stats">
        <div class="stat">
            <span class="stat-num" data-target="@Model.TotalCars" data-suffix="+">0</span>
            <span class="stat-label">Автомобилей в наличии</span>
        </div>
        <div class="stat">
            <span class="stat-num" data-target="12" data-suffix=" лет">0</span>
            <span class="stat-label">На рынке</span>
        </div>
        <div class="stat">
            <span class="stat-num" data-target="8000" data-suffix="+">0</span>
            <span class="stat-label">Довольных клиентов</span>
        </div>
        <div class="stat">
            <span class="stat-num" data-target="100" data-suffix="%">0</span>
            <span class="stat-label">Легальных сделок</span>
        </div>
    </div>
</section>

<!-- ═══ FEATURED CARS ═══ -->
<section class="section">
    <div class="section-label">Избранное</div>
    <h2 class="section-title">Популярные модели</h2>

    @if (Model.FeaturedCars.Any())
    {
        <div class="cars-grid">
            @foreach (var car in Model.FeaturedCars)
            {
                <div class="car-card">
                    <div class="car-img-wrap">
                        @if (car.MainPhoto != null)
                        {
                            <img src="@car.MainPhoto.FilePath" alt="@car.Brand @car.Model" loading="lazy">
                        }
                        else
                        {
                            <div class="car-img-placeholder">🚗</div>
                        }
                        @if (car.Status == AutoSalon.Models.CarStatus.Sold)
                        {
                            <span class="car-badge-sold">Продан</span>
                        }
                        else if (car.Badge != null && car.Badge.IsVerified)
                        {
                            <span class="car-badge-pill">Проверен</span>
                        }
                        else if (car.Badge != null && car.Badge.HasWarranty)
                        {
                            <span class="car-badge-pill">Гарантия</span>
                        }
                        else if (car.Badge != null && car.Badge.HasExchange)
                        {
                            <span class="car-badge-pill">Обмен</span>
                        }
                        else if (car.Mileage == 0)
                        {
                            <span class="car-badge-pill">Новый</span>
                        }
                        else
                        {
                            <span class="car-badge-pill">В наличии</span>
                        }
                    </div>
                    <div class="car-body">
                        <div class="car-name">@car.Brand @car.Model</div>
                        <div class="car-year">@car.Year год · @car.City</div>
                        <div class="car-price">@car.DisplayPrice</div>
                        <div class="car-specs">
                            <div class="spec">⏱ @car.DisplayMileage</div>
                            <div class="spec">⚙️ @car.FuelType</div>
                            <div class="spec">🔄 @car.Transmission</div>
                            <div class="spec">📦 @car.BodyType</div>
                        </div>
                        <a href="/car/@car.Slug" class="car-link">Подробнее →</a>
                    </div>
                </div>
            }
        </div>
        <div class="view-all-wrap">
            <a href="/catalog" class="btn-gold btn-gold-lg">Смотреть все автомобили →</a>
        </div>
    }
    else
    {
        <div class="cars-empty">
            <span>🚗</span>
            Автомобили появятся совсем скоро
        </div>
    }
</section>

<!-- ═══ BRANDS ═══ -->
@if (Model.TopBrands.Any())
{
    <section class="section brands-section">
        <div class="section-label">Марки</div>
        <h2 class="section-title">Все бренды</h2>
        <div class="brands-grid">
            @foreach (var brand in Model.TopBrands)
            {
                <a href="/catalog?brand=@Uri.EscapeDataString(brand)" class="brand-pill">@brand</a>
            }
        </div>
    </section>
}

<!-- ═══ WHY US ═══ -->
<section class="section">
    <div class="section-label">Почему мы</div>
    <h2 class="section-title">Ваш надёжный партнёр</h2>
    <div class="features-grid">
        <div class="feature">
            <div class="feature-icon">🛡</div>
            <div class="feature-title">Официальная гарантия</div>
            <div class="feature-desc">Все автомобили проходят полную проверку и имеют официальную гарантию производителя.</div>
        </div>
        <div class="feature">
            <div class="feature-icon">📄</div>
            <div class="feature-title">Юридическая чистота</div>
            <div class="feature-desc">Проверяем каждый автомобиль по всем базам данных. Никаких скрытых проблем.</div>
        </div>
        <div class="feature">
            <div class="feature-icon">💳</div>
            <div class="feature-title">Кредит от 0.1%</div>
            <div class="feature-desc">Партнёрство с ведущими банками. Одобрение за 30 минут прямо в салоне.</div>
        </div>
        <div class="feature">
            <div class="feature-icon">🔄</div>
            <div class="feature-title">Трейд-ин</div>
            <div class="feature-desc">Обменяйте ваш автомобиль на новый. Оценка и оформление за один визит.</div>
        </div>
    </div>
</section>

<!-- ═══ CTA ═══ -->
<section class="cta-section">
    <div class="section-label">Готовы начать?</div>
    <h2 class="section-title">Найдём автомобиль<br>специально для вас</h2>
    <p>Наши специалисты помогут подобрать идеальный вариант под ваш бюджет и предпочтения.</p>
    <div class="cta-actions">
        <a href="/catalog" class="btn-gold btn-gold-lg">Смотреть каталог →</a>
        <a href="/about" class="btn-outline">Связаться с нами</a>
    </div>
</section>

<!-- ═══ FOOTER ═══ -->
<footer class="footer">
    <div class="footer-grid">
        <div class="footer-brand">
            <a href="/" class="nav-logo">
                <div class="nav-logo-icon">🚗</div>
                <span class="nav-logo-text">@(Model.Settings?.SalonName ?? "Автопрайм")</span>
            </a>
            <p>Премиальный автосалон с широким выбором автомобилей от ведущих мировых производителей.</p>
        </div>
        <div class="footer-col">
            <div class="footer-col-title">Навигация</div>
            <ul>
                <li><a href="/">Главная</a></li>
                <li><a href="/catalog">Автомобили</a></li>
                <li><a href="/about">О нас</a></li>
            </ul>
        </div>
        <div class="footer-col">
            <div class="footer-col-title">Контакты</div>
            <div class="footer-contact">
                @if (!string.IsNullOrEmpty(Model.Settings?.Phone))
                {
                    <div class="footer-contact-item">📞 @Model.Settings.Phone</div>
                }
                @if (!string.IsNullOrEmpty(Model.Settings?.Email))
                {
                    <div class="footer-contact-item">✉️ @Model.Settings.Email</div>
                }
                @if (!string.IsNullOrEmpty(Model.Settings?.Address))
                {
                    <div class="footer-contact-item">📍 @Model.Settings.Address</div>
                }
            </div>
        </div>
        <div class="footer-col">
            <div class="footer-col-title">Режим работы</div>
            <div class="footer-contact">
                @if (!string.IsNullOrEmpty(Model.Settings?.WorkingHours))
                {
                    <div class="footer-contact-item">⏰ @Model.Settings.WorkingHours</div>
                }
                else
                {
                    <div class="footer-contact-item">⏰ Пн–Пт: 9:00 – 20:00</div>
                    <div class="footer-contact-item">⏰ Сб–Вс: 10:00 – 18:00</div>
                }
            </div>
        </div>
    </div>
    <div class="footer-bottom">
        <span>© @DateTime.Now.Year @(Model.Settings?.SalonName ?? "Автопрайм"). Все права защищены.</span>
        <span>Казахстан</span>
    </div>
</footer>

<script>
    const counters = document.querySelectorAll('.stat-num[data-target]');
    const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            const el = entry.target;
            const target = +el.dataset.target;
            const suffix = el.dataset.suffix || '';
            const step = Math.max(1, Math.ceil(target / 80));
            let current = 0;
            const timer = setInterval(() => {
                current = Math.min(current + step, target);
                el.textContent = current.toLocaleString('ru') + suffix;
                if (current >= target) clearInterval(timer);
            }, 16);
            observer.unobserve(el);
        });
    }, { threshold: 0.5 });
    counters.forEach(c => observer.observe(c));
</script>
</body>
</html>
