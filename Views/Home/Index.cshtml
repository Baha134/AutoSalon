@section Scripts {
<script>
// Navbar scroll effect
(function () {
    var nav = document.querySelector('.navbar');
    if (!nav) return;
    function check() { nav.classList.toggle('hp-scrolled', window.scrollY > 50); }
    window.addEventListener('scroll', check, { passive: true });
    check();
})();

// Animated counters
(function () {
    var els = document.querySelectorAll('.hp-stat-n[data-target]');
    var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
            if (!e.isIntersecting) return;
            var el = e.target;
            var target = +el.dataset.target;
            var suffix = el.dataset.suffix || '';
            var step = Math.max(1, Math.ceil(target / 70));
            var cur = 0;
            var t = setInterval(function () {
                cur = Math.min(cur + step, target);
                el.textContent = cur.toLocaleString('ru') + suffix;
                if (cur >= target) clearInterval(t);
            }, 16);
            obs.unobserve(el);
        });
    }, { threshold: 0.4 });
    els.forEach(function (el) { obs.observe(el); });
})();
</script>
}
