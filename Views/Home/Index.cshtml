@model AutoSalon.ViewModels.HomeViewModel
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AutoSalon.Resources.SharedResource> L
@{
    ViewData["Title"] = (Model.Settings?.SalonName ?? "Автопрайм") + " — Премиальный автосалон";
    ViewData["Description"] = "Более " + Model.TotalCars + " автомобилей в наличии. Официальная гарантия, юридическая чистота, выгодные условия трейд-ин и кредита.";
}

@section Styles {
    <style>
        /* Дополнительные стили только для главной страницы (если нужны) */
        .hero-stats .hero-stat-value {
            font-family: var(--font-display);
        }

        .hero {
            margin-top: 0;
        }
    </style>
}

<!-- HERO SECTION -->
<section class="hero">
    <div class="container">
        <div class="hero-eyebrow">
            <span>✨</span> Премиальный автосалон
        </div>
        <h1 class="hero-title">
            Найдите автомобиль<br>
            <span>вашей мечты</span>
        </h1>
        <p class="hero-sub">
            Более @Model.TotalCars автомобилей в наличии. Официальная гарантия,
            юридическая чистота, выгодные условия трейд-ин и кредита.
        </p>
        <div class="hero-actions">
            <a href="/catalog" class="btn-gold">Смотреть каталог →</a>
            <a href="/about" class="btn-outline">О салоне</a>
        </div>

        <div class="hero-stats">
            <div class="hero-stat">
                <div class="hero-stat-value" data-target="@Model.TotalCars" data-suffix="+">0</div>
                <div class="hero-stat-label">Авто в наличии</div>
            </div>
            <div class="hero-stat">
                <div class="hero-stat-value" data-target="12" data-suffix=" лет">0</div>
                <div class="hero-stat-label">На рынке</div>
            </div>
            <div class="hero-stat">
                <div class="hero-stat-value" data-target="8000" data-suffix="+">0</div>
                <div class="hero-stat-label">Клиентов</div>
            </div>
            <div class="hero-stat">
                <div class="hero-stat-value" data-target="100" data-suffix="%">0</div>
                <div class="hero-stat-label">Легальных сделок</div>
            </div>
        </div>
    </div>
</section>

<!-- FEATURED CARS SECTION -->
<section class="container" style="padding: 60px 0;">
    <div class="section-header">
        <div>
            <div class="section-title">Популярные модели</div>
        </div>
        <a href="/catalog" class="section-link">Все автомобили →</a>
    </div>

    @if (Model.FeaturedCars.Any())
    {
        <div class="car-grid">
            @foreach (var car in Model.FeaturedCars)
            {
                <partial name="_CarCard" model="car" />
            }
        </div>
        <div class="text-center mt-5">
            <a href="/catalog" class="btn-gold">Смотреть все автомобили →</a>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">🚗</div>
            <h3>@L["Home_NoCars"]</h3>
        </div>
    }
</section>

<!-- BRANDS SECTION -->
@if (Model.TopBrands.Any())
{
    <section style="background: var(--color-bg-secondary); padding: 60px 0;">
        <div class="container">
            <div class="section-header">
                <div class="section-title">Марки в наличии</div>
            </div>
            <div class="brand-grid">
                @foreach (var brand in Model.TopBrands.Take(12))
                {
                    <a href="/catalog?Brand=@Uri.EscapeDataString(brand)" class="brand-chip">@brand</a>
                }
            </div>
        </div>
    </section>
}

<!-- WHY US SECTION -->
<section class="container" style="padding: 60px 0;">
    <div class="section-header">
        <div class="section-title">Почему выбирают нас</div>
    </div>
    <div class="why-grid">
        <div class="why-card">
            <div class="why-icon">🛡</div>
            <div class="why-title">Официальная гарантия</div>
            <div class="why-sub">Все автомобили проходят полную проверку и имеют официальную гарантию производителя.</div>
        </div>
        <div class="why-card">
            <div class="why-icon">📄</div>
            <div class="why-title">Юридическая чистота</div>
            <div class="why-sub">Проверяем каждый автомобиль по всем базам данных. Никаких скрытых проблем.</div>
        </div>
        <div class="why-card">
            <div class="why-icon">💳</div>
            <div class="why-title">Кредит от 0.1%</div>
            <div class="why-sub">Партнёрство с ведущими банками. Одобрение за 30 минут прямо в салоне.</div>
        </div>
        <div class="why-card">
            <div class="why-icon">🔄</div>
            <div class="why-title">Трейд-ин</div>
            <div class="why-sub">Обменяйте ваш автомобиль на новый. Оценка и оформление за один визит.</div>
        </div>
    </div>
</section>

<!-- CTA SECTION with Lead Form (critical: class lead-form, id lead-anchor) -->
<section class="container" style="padding: 0 0 60px;">
    <div class="cta-section" id="lead-anchor">
        <h2 class="cta-title">Готовы найти свой автомобиль?</h2>
        <p class="cta-text">Наши специалисты помогут подобрать идеальный вариант под ваш бюджет и предпочтения.</p>

        <form method="post" action="/leads" class="lead-form" style="max-width: 480px; margin: 0 auto;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="CarId" value="" />
            <input type="hidden" name="LeadType" value="Call" />
            <!-- Honeypot поле (обязательно) -->
            <input type="text" name="Website" style="display:none" tabindex="-1" autocomplete="off" />

            <input type="text" name="Name" class="form-control mb-2" placeholder="@L["Home_Form_Name"]" required maxlength="100" />
            <input type="tel" name="Phone" class="form-control mb-2" placeholder="@L["Home_Form_Phone"]" required maxlength="20" />
            <textarea name="Message" class="form-control mb-3" rows="2" placeholder="@L["Home_Form_Message"]"></textarea>
            <button type="submit" class="btn-submit">@L["Home_Form_Submit"]</button>
            <p class="small text-muted mt-2">@L["Home_Form_Agree"]</p>
        </form>
    </div>
</section>

@section Scripts {
    <script>
        // Анимация счётчиков в hero-статистике
        (function() {
            const counters = document.querySelectorAll('.hero-stat-value[data-target]');
            if (!counters.length) return;
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (!entry.isIntersecting) return;
                    const el = entry.target;
                    const target = parseInt(el.dataset.target, 10);
                    const suffix = el.dataset.suffix || '';
                    let current = 0;
                    const step = Math.ceil(target / 60);
                    const timer = setInterval(() => {
                        current = Math.min(current + step, target);
                        el.textContent = current.toLocaleString('ru-RU') + suffix;
                        if (current >= target) clearInterval(timer);
                    }, 20);
                    observer.unobserve(el);
                });
            }, { threshold: 0.5 });
            counters.forEach(c => observer.observe(c));
        })();
    </script>
}