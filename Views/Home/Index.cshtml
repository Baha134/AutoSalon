@model AutoSalon.ViewModels.HomeViewModel

@{
    ViewData["Title"] = L["Home_Title"];
    ViewData["Description"] = "Продажа автомобилей с пробегом и новых. " + Model.TotalCars + " автомобилей в наличии.";
}

<!-- HERO -->
<section class="hero">
    <div class="container">
        <h1 class="hero-title">@L["Home_Title"]</h1>
        <p class="hero-sub">@string.Format(L["Home_Cars_In_Stock"], Model.TotalCars)</p>

        <form class="hero-search" action="/catalog" method="get">
            <input type="text" name="Search" placeholder="@L["Home_Search_Placeholder"]" autocomplete="off" />
            <button type="submit">@L["Home_Search_Button"]</button>
        </form>

        <div class="budget-btns">
            <a class="budget-btn" href="/catalog?PriceMax=5000000">до 5 млн ₸</a>
            <a class="budget-btn" href="/catalog?PriceMin=5000000&PriceMax=10000000">5–10 млн ₸</a>
            <a class="budget-btn" href="/catalog?PriceMin=10000000&PriceMax=20000000">10–20 млн ₸</a>
            <a class="budget-btn" href="/catalog?PriceMin=20000000">от 20 млн ₸</a>
        </div>

        @if (Model.TopBrands.Any())
        {
            <div class="brand-grid">
                @foreach (var brand in Model.TopBrands.Take(12))
                {
                    <a class="brand-chip" href="/catalog?Brand=@Uri.EscapeDataString(brand)">@brand</a>
                }
            </div>
        }
    </div>
</section>

<!-- РЕКОМЕНДУЕМЫЕ АВТО -->
<div class="container mt-5">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h2 class="section-title mb-0">@L["Home_Recent"]</h2>
        <a href="/catalog" class="btn btn-outline-primary btn-sm">@L["Home_AllCatalog"]</a>
    </div>

    @if (Model.FeaturedCars.Any())
    {
        <div class="car-grid">
            @foreach (var car in Model.FeaturedCars)
            {
                <partial name="_CarCard" model="car" />
            }
        </div>
    }
    else
    {
        <div class="empty-state py-5">
            <div class="empty-icon">🚗</div>
            <h3>@L["Home_NoCars"]</h3>
            <a href="#lead-anchor" class="btn btn-secondary">@L["Home_LeaveRequest"]</a>
        </div>
    }
</div>

<!-- ФОРМА ЗАЯВКИ -->
<div class="container mt-5" id="lead-anchor">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm p-4">
                <h3 class="fw-bold mb-1">@L["Home_NotFound"]</h3>
                <p class="text-muted small mb-4">@L["Home_NotFound_Sub"]</p>
                <form class="lead-form" method="post" action="/leads">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="LeadType" value="Call" />
                    <input type="text" name="Website" style="display:none" tabindex="-1" autocomplete="off" />
                    <div class="mb-3">
                        <input type="text" name="Name" class="form-control" placeholder="@L["Home_Form_Name"]" required maxlength="100" />
                    </div>
                    <div class="mb-3">
                        <input type="tel" name="Phone" class="form-control" placeholder="@L["Home_Form_Phone"]" required />
                    </div>
                    <div class="mb-3">
                        <textarea name="Message" class="form-control" rows="2" placeholder="@L["Home_Form_Message"]"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">@L["Home_Form_Submit"]</button>
                    <p class="text-muted text-center mt-2" style="font-size:11px">@L["Home_Form_Agree"]</p>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- ПРЕИМУЩЕСТВА -->
<div class="container mt-5 mb-5">
    <h2 class="section-title text-center mb-4">@L["Home_Why_Title"]</h2>
    <div class="row g-4 text-center">
        <div class="col-md-3">
            <div class="p-3">
                <div style="font-size:40px;margin-bottom:12px">✅</div>
                <div class="fw-bold mb-1">@L["Home_Why_1_Title"]</div>
                <div class="text-muted small">@L["Home_Why_1_Sub"]</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3">
                <div style="font-size:40px;margin-bottom:12px">🏦</div>
                <div class="fw-bold mb-1">@L["Home_Why_2_Title"]</div>
                <div class="text-muted small">@string.Format(L["Home_Why_2_Sub"], Model.Settings?.CreditRate ?? 18)</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3">
                <div style="font-size:40px;margin-bottom:12px">🔄</div>
                <div class="fw-bold mb-1">@L["Home_Why_3_Title"]</div>
                <div class="text-muted small">@L["Home_Why_3_Sub"]</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3">
                <div style="font-size:40px;margin-bottom:12px">🛡</div>
                <div class="fw-bold mb-1">@L["Home_Why_4_Title"]</div>
                <div class="text-muted small">@L["Home_Why_4_Sub"]</div>
            </div>
        </div>
    </div>
</div>