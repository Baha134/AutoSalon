@{
    ViewData["Title"] = L["Error_Title"];
    ViewData["NoIndex"] = true;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5 text-center">
    <div class="empty-state">
        <div style="font-size:80px;font-weight:900;color:#e0e4ea;line-height:1">404</div>
        <h2 class="fw-bold mt-3 mb-2">@L["Error_Title"]</h2>
        <p class="text-muted mb-4">@L["Error_Sub"]</p>
        <div class="d-flex gap-3 justify-content-center">
            <a href="/" class="btn btn-primary">@L["Error_Home"]</a>
            <a href="/catalog" class="btn btn-outline-secondary">@L["Error_Catalog"]</a>
        </div>
    </div>
</div>