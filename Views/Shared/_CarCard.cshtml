@model AutoSalon.Models.Car
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AutoSalon.Resources.SharedResource> L

@{
    var isSold = Model.Status == AutoSalon.Models.CarStatus.Sold;
    var isReserved = Model.Status == AutoSalon.Models.CarStatus.Reserved;
    var mainPhoto = Model.MainPhoto;
    var hasBadge = Model.Badge != null;
}

<div class="car-card fade-up">
    <div class="car-card-img">
        <a href="/car/@Model.Slug" class="car-card-img-link">
            @if (mainPhoto != null)
            {
                <img src="@mainPhoto.FilePath" alt="@Model.Brand @Model.Model @Model.Year" loading="lazy" />
            }
            else
            {
                <div class="no-photo">🚗</div>
            }
        </a>

        <!-- Status badge -->
        @if (isSold)
        {
            <div class="status-badge status-sold">@L["Card_Sold"]</div>
        }
        else if (isReserved)
        {
            <div class="status-badge status-reserved">@L["Card_Reserved"]</div>
        }
        else if (hasBadge && Model.Badge!.IsVerified)
        {
            <div class="status-badge status-active">✔ @L["Card_Verified"]</div>
        }
        else if (hasBadge && Model.Badge!.HasWarranty)
        {
            <div class="status-badge status-active">🛡 @L["Card_Warranty"]</div>
        }
        else if (hasBadge && Model.Badge!.HasExchange)
        {
            <div class="status-badge status-active">🔄 @L["Card_Exchange"]</div>
        }

        <!-- Favorite button (critical for favorite.js) -->
        <button class="fav-btn btn-favorite"
                data-id="@Model.Id"
                data-is-fav="0"
                title="@L["Detail_Favorite"]">
            <span class="fav-icon">♡</span>
        </button>

        <!-- Compare button (critical for compare.js) -->
        <button class="compare-btn btn-compare"
                data-id="@Model.Id"
                data-in-compare="0"
                title="@L["Card_Compare"]">
            ⚖ @L["Card_Compare"]
        </button>
    </div>

    <div class="car-card-body">
        <a href="/car/@Model.Slug" class="car-card-title">@Model.Brand @Model.Model @Model.Year</a>
        <div class="car-card-price">@Model.DisplayPrice</div>

        <div class="car-card-specs">
            <span>⏱ @Model.DisplayMileage</span>
            <span>⚙️ @Model.FuelType</span>
            <span>🔄 @Model.Transmission</span>
            <span>📦 @Model.BodyType</span>
        </div>

        <!-- Badges row (if needed) -->
        @if (hasBadge && (Model.Badge!.IsVerified || Model.Badge!.HasWarranty || Model.Badge!.HasExchange))
        {
            <div class="car-badges">
                @if (Model.Badge.IsVerified)
                {
                    <span class="car-badge badge-verified">✔ @L["Card_Verified"]</span>
                }
                @if (Model.Badge.HasWarranty)
                {
                    <span class="car-badge badge-warranty">🛡 @L["Card_Warranty"]</span>
                }
                @if (Model.Badge.HasExchange)
                {
                    <span class="car-badge badge-exchange">🔄 @L["Card_Exchange"]</span>
                }
            </div>
        }

        <div class="car-card-footer">
            @if (isSold)
            {
                <span class="btn-card-sold">@L["Card_Sold"]</span>
            }
            else if (isReserved)
            {
                <a href="/car/@Model.Slug" class="btn-card-reserved">@L["Card_Details_Reserved"]</a>
            }
            else
            {
                <a href="/car/@Model.Slug" class="btn-card-detail">@L["Card_Details"] →</a>
            }
        </div>
    </div>
</div>