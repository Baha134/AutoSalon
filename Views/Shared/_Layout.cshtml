@using Microsoft.AspNetCore.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AutoSalon.Resources.SharedResource> L
@{
    var currentCulture = Context.Features.Get<IRequestCultureFeature>()?.RequestCulture.Culture.TwoLetterISOLanguageName ?? "ru";
    var returnUrl = Context.Request.Path.ToString();
}

<!DOCTYPE html>
<html lang="@currentCulture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — @L["Site_Name"]</title>
    <meta name="description" content="@(ViewData["Description"] ?? "Продажа автомобилей с пробегом и новых. Каталог, кредит, обмен.")" />
    @if (ViewData["NoIndex"] != null)
    {
        <meta name="robots" content="noindex" />
    }

    <!-- Open Graph / Social -->
    <meta property="og:site_name" content="@L["Site_Name"]" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:url" content="https://@Context.Request.Host@Context.Request.Path" />
    @if (ViewData["OgTitle"] != null)
    {
        <meta property="og:type" content="product" />
        <meta property="og:title" content="@ViewData["OgTitle"]" />
        <meta property="og:description" content="@ViewData["OgDescription"]" />
        @if (!string.IsNullOrEmpty(ViewData["OgImage"]?.ToString()))
        {
            <meta property="og:image" content="https://@Context.Request.Host@ViewData["OgImage"]" />
            <meta property="og:image:width" content="1200" />
            <meta property="og:image:height" content="630" />
        }
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content="@ViewData["OgTitle"]" />
        <meta name="twitter:description" content="@ViewData["OgDescription"]" />
        @if (!string.IsNullOrEmpty(ViewData["OgImage"]?.ToString()))
        {
            <meta name="twitter:image" content="https://@Context.Request.Host@ViewData["OgImage"]" />
        }
    }
    else
    {
        <meta property="og:type" content="website" />
        <meta property="og:title" content="@(ViewData["Title"] != null ? ViewData["Title"] + " — " + L["Site_Name"] : L["Site_Name"].ToString())" />
        <meta property="og:description" content="@(ViewData["Description"] ?? "Продажа автомобилей с пробегом и новых. Каталог, кредит, обмен.")" />
    }

    <!-- Preconnect + Google Fonts (Inter + Manrope) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5 (CSS only, we use custom theme) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous" />

    <!-- Main site CSS (new light premium theme) -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- Fixed Navbar with blur effect -->
    <nav class="navbar" id="mainNavbar">
        <div class="container">
            <a class="navbar-brand" href="/">
                @L["Site_Brand_1"]<span>@L["Site_Brand_2"]</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu" aria-controls="navMenu" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="/catalog">@L["Nav_Catalog"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/calculator">💳 Кредит</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/about">@L["Nav_About"]</a>
                    </li>
                </ul>

                <ul class="navbar-nav align-items-center gap-2">
                    <!-- Compare link with counter -->
                    <li class="nav-item">
                        <a class="nav-link d-flex align-items-center gap-1" href="/compare" title="@L["Nav_Compare"]">
                            <span style="font-size: 1.2rem;">⚖️</span>
                            <span class="navbar-compare-count" id="compare-count" style="display:none">0</span>
                        </a>
                    </li>
                    <!-- Favorites link with counter -->
                    <li class="nav-item">
                        <a class="nav-link d-flex align-items-center gap-1" href="/favorites" title="@L["Nav_Favorites"]">
                            <span style="font-size: 1.2rem;">❤️</span>
                            <span class="navbar-fav-count" id="fav-count" style="display:none">0</span>
                        </a>
                    </li>
                    <!-- Language switcher -->
                    <li class="nav-item ms-2">
                        <div class="d-flex gap-1 align-items-center">
                            <a href="/language/set?culture=ru&returnUrl=@Uri.EscapeDataString(returnUrl)"
                               class="lang-btn @(currentCulture == "ru" ? "active" : "")">RU</a>
                            <a href="/language/set?culture=kk&returnUrl=@Uri.EscapeDataString(returnUrl)"
                               class="lang-btn @(currentCulture == "kk" ? "active" : "")">KZ</a>
                            <a href="/language/set?culture=en&returnUrl=@Uri.EscapeDataString(returnUrl)"
                               class="lang-btn @(currentCulture == "en" ? "active" : "")">EN</a>
                        </div>
                    </li>
                    <!-- Login partial -->
                    <partial name="_LoginPartial" />
                </ul>
            </div>
        </div>
    </nav>

    <!-- Global success message for leads (non-AJAX fallback) -->
    @if (TempData["LeadSuccess"] != null)
    {
        <div class="container mt-3">
            <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
                ✅ @L["Lead_Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    }

    <main>
        @RenderBody()
    </main>

    <!-- Footer dark blue -->
    <footer class="site-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="footer-brand">@L["Site_Brand_1"]<span>@L["Site_Brand_2"]</span></div>
                    <div class="footer-tagline">@L["Home_Hero_Subtitle"]</div>
                </div>
                <div class="col-md-2">
                    <div class="footer-heading">@L["Nav_Catalog"]</div>
                    <ul class="footer-links">
                        <li><a href="/catalog">@L["Nav_Catalog"]</a></li>
                        <li><a href="/compare">@L["Nav_Compare"]</a></li>
                        <li><a href="/favorites">@L["Nav_Favorites"]</a></li>
                    </ul>
                </div>
                <div class="col-md-2">
                    <div class="footer-heading">Компания</div>
                    <ul class="footer-links">
                        <li><a href="/about">@L["Nav_About"]</a></li>
                        <li><a href="/calculator">💳 Кредит</a></li>
                        <li><a href="/sitemap.xml">Sitemap</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <div class="footer-heading">Контакты</div>
                    <ul class="footer-links">
                        <li><a href="#">📍 Кокшетау, ул. Абая 1</a></li>
                        <li><a href="#">🕐 Пн–Вс: 9:00 — 20:00</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <span>© @DateTime.Now.Year @L["Site_Name"]. Все права защищены.</span>
                <span>Казахстан · Кредит · Трейд-ин · Гарантия</span>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="~/js/favorite.js" asp-append-version="true"></script>
    <script src="~/js/compare.js" asp-append-version="true"></script>
    <script src="~/js/sticky-cta.js" asp-append-version="true"></script>
    <script src="~/js/gallery.js" asp-append-version="true"></script>

    <!-- Navbar scroll effect -->
    <script>
        (function() {
        const navbar = document.getElementById('mainNavbar');
        if (!navbar) return;
        window.addEventListener('scroll', function() {
        if (window.scrollY > 50) {
        navbar.classList.add('navbar-scrolled');
        } else {
        navbar.classList.remove('navbar-scrolled');
        }
        });
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>