@using Microsoft.AspNetCore.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AutoSalon.Resources.SharedResource> L
@{
    var currentCulture = Context.Features.Get<IRequestCultureFeature>()?.RequestCulture.Culture.TwoLetterISOLanguageName ?? "ru";
    var returnUrl = Context.Request.Path.ToString();
    
}

<!DOCTYPE html>
<html lang="@currentCulture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] — @L["Site_Name"]</title>
    <meta name="description" content="@(ViewData["Description"] ?? "Продажа автомобилей с пробегом и новых. Каталог, кредит, обмен.")" />
    @if (ViewData["NoIndex"] != null)
    {
        <meta name="robots" content="noindex" />
    }
    @if (ViewData["OgTitle"] != null)
    {
        <meta property="og:title" content="@ViewData["OgTitle"]" />
        <meta property="og:description" content="@ViewData["OgDescription"]" />
        <meta property="og:image" content="@ViewData["OgImage"]" />
        <meta property="og:type" content="website" />
    }
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .lang-switcher {
            display: flex;
            gap: 4px;
            align-items: center;
        }
        .lang-switcher a {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-decoration: none;
            color: rgba(255,255,255,0.65);
            border: 1px solid rgba(255,255,255,0.2);
            transition: all 0.2s;
        }
        .lang-switcher a:hover {
            color: #fff;
            border-color: rgba(255,255,255,0.6);
            background: rgba(255,255,255,0.1);
        }
        .lang-switcher a.active {
            color: #fff;
            background: rgba(255,255,255,0.2);
            border-color: rgba(255,255,255,0.5);
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <a class="navbar-brand" href="/">@L["Site_Brand_1"]<span>@L["Site_Brand_2"]</span></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/catalog">@L["Nav_Catalog"]</a></li>
                    <li class="nav-item"><a class="nav-link" href="/about">@L["Nav_About"]</a></li>
                </ul>
                <ul class="navbar-nav gap-2 align-items-center">
                    <li class="nav-item">
                        <a class="nav-link" href="/compare" title="@L["Nav_Compare"]">
                            ⚖️
                            <span class="compare-count" id="compare-count" style="display:none">0</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/favorites" title="@L["Nav_Favorites"]">
                            ❤️
                            <span class="fav-count" id="fav-count" style="display:none">0</span>
                        </a>
                    </li>
                    <li class="nav-item d-flex align-items-center ms-2">
                        <div class="lang-switcher">
                            <a href="/language/set?culture=ru&amp;returnUrl=@Uri.EscapeDataString(returnUrl)"
                               class="@(currentCulture == "ru" ? "active" : "")">RU</a>
                            <a href="/language/set?culture=kk&amp;returnUrl=@Uri.EscapeDataString(returnUrl)"
                               class="@(currentCulture == "kk" ? "active" : "")">KZ</a>
                            <a href="/language/set?culture=en&amp;returnUrl=@Uri.EscapeDataString(returnUrl)"
                               class="@(currentCulture == "en" ? "active" : "")">EN</a>
                        </div>
                    </li>
                </ul>
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>

    @if (TempData["LeadSuccess"] != null)
    {
        <div class="container mt-3">
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                ✅ @L["Lead_Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <main>
        @RenderBody()
    </main>

    <footer class="footer mt-5 py-4">
        <div class="container">
            <div class="row">
                <div class="col-md-4">
                    <div class="fw-bold mb-2">@L["Site_Brand_1"]<span style="color:#f0ad00">@L["Site_Brand_2"]</span></div>
                    <div class="text-muted small">@L["Home_Hero_Subtitle"]</div>
                </div>
                <div class="col-md-4">
                    <div class="small text-muted">
                        <a href="/catalog" class="d-block mb-1 text-muted">@L["Nav_Catalog"]</a>
                        <a href="/compare" class="d-block mb-1 text-muted">@L["Nav_Compare"]</a>
                        <a href="/favorites" class="d-block mb-1 text-muted">@L["Nav_Favorites"]</a>
                        <a href="/about" class="d-block mb-1 text-muted">@L["Nav_About"]</a>
                    </div>
                </div>
                <div class="col-md-4 text-md-end">
                    <div class="small text-muted">
                        <a href="/sitemap.xml" class="text-muted">Sitemap</a>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <div class="sticky-cta" id="sticky-cta">
        <a href="#lead-anchor" class="cta-btn cta-call w-100">📞 @L["Lead_Title"]</a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
            crossorigin="anonymous"></script>
    <script src="~/js/favorite.js" asp-append-version="true"></script>
    <script src="~/js/compare.js" asp-append-version="true"></script>
    <script src="~/js/gallery.js" asp-append-version="true"></script>
    <script src="~/js/sticky-cta.js" asp-append-version="true"></script>

    <script>
        window.currentLang = '@currentCulture';
    </script>

    <script>
        (async function () {
            try {
                const [fav, cmp] = await Promise.all([
                    fetch('/favorites/count').then(r => r.json()),
                    fetch('/compare/count').then(r => r.json())
                ]);
                const favEl = document.getElementById('fav-count');
                const cmpEl = document.getElementById('compare-count');
                if (fav.count > 0) { favEl.textContent = fav.count; favEl.style.display = ''; }
                if (cmp.count > 0) { cmpEl.textContent = cmp.count; cmpEl.style.display = ''; }
            } catch (e) {}
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
