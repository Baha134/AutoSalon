@using Microsoft.AspNetCore.Localization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AutoSalon.Resources.SharedResource> L
@{
    var currentCulture = Context.Features.Get<IRequestCultureFeature>()?.RequestCulture.Culture.TwoLetterISOLanguageName ?? "ru";
    var returnUrl = Context.Request.Path.ToString();
}

<!DOCTYPE html>
<html lang="@currentCulture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] — @L["Site_Name"]</title>
    <meta name="description" content="@(ViewData["Description"] ?? "Продажа автомобилей с пробегом и новых. Каталог, кредит, обмен.")" />
    @if (ViewData["NoIndex"] != null)
    {
        <meta name="robots" content="noindex" />
    }
    @if (ViewData["OgTitle"] != null)
    {
        <meta property="og:title" content="@ViewData["OgTitle"]" />
        <meta property="og:description" content="@ViewData["OgDescription"]" />
        <meta property="og:image" content="@ViewData["OgImage"]" />
        <meta property="og:type" content="website" />
    }

    <!-- Google Fonts: Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ═══════════════ NAVBAR ═══════════════ -->
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">
            <!-- Логотип -->
            <a class="navbar-brand" href="/">
                @L["Site_Brand_1"]<span>@L["Site_Brand_2"]</span>
            </a>

            <!-- Бургер (мобайл) -->
            <button class="navbar-toggler border-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navMenu"
                    style="color:rgba(255,255,255,.7);">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">
                <!-- Левые ссылки -->
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/catalog">@L["Nav_Catalog"]</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/calculator">💳 Кредит</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/about">@L["Nav_About"]</a>
                    </li>
                </ul>

                <!-- Правые элементы -->
                <ul class="navbar-nav align-items-center gap-1">

                    <!-- Сравнение -->
                    <li class="nav-item">
                        <a class="nav-link d-flex align-items-center gap-1" href="/compare" title="@L["Nav_Compare"]">
                            <span style="font-size:16px;">⚖️</span>
                            <span class="navbar-compare-count" id="compare-count" style="display:none">0</span>
                        </a>
                    </li>

                    <!-- Избранное -->
                    <li class="nav-item">
                        <a class="nav-link d-flex align-items-center gap-1" href="/favorites" title="@L["Nav_Favorites"]">
                            <span style="font-size:16px;">❤️</span>
                            <span class="navbar-fav-count" id="fav-count" style="display:none">0</span>
                        </a>
                    </li>

                    <!-- Языки -->
                    <li class="nav-item ms-2">
                        <div class="d-flex gap-1 align-items-center">
                            <a href="/language/set?culture=ru&returnUrl=@Uri.EscapeDataString(returnUrl)"
                               class="lang-btn @(currentCulture == "ru" ? "active" : "")">RU</a>
                            <a href="/language/set?culture=kk&returnUrl=@Uri.EscapeDataString(returnUrl)"
                               class="lang-btn @(currentCulture == "kk" ? "active" : "")">KZ</a>
                            <a href="/language/set?culture=en&returnUrl=@Uri.EscapeDataString(returnUrl)"
                               class="lang-btn @(currentCulture == "en" ? "active" : "")">EN</a>
                        </div>
                    </li>

                    <!-- Логин/Регистрация -->
                    <partial name="_LoginPartial" />
                </ul>
            </div>
        </div>
    </nav>

    <!-- Уведомление об успешной заявке -->
    @if (TempData["LeadSuccess"] != null)
    {
        <div class="container mt-3">
            <div class="alert alert-success alert-dismissible fade show rounded-3 border-0"
                 style="background:#DCFCE7;color:#15803D;font-weight:600;" role="alert">
                ✅ @L["Lead_Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }

    <!-- Основной контент -->
    <main>
        @RenderBody()
    </main>

    <!-- ═══════════════ FOOTER ═══════════════ -->
    <footer class="site-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="footer-brand">@L["Site_Brand_1"]<span>@L["Site_Brand_2"]</span></div>
                    <div class="footer-tagline">@L["Home_Hero_Subtitle"]</div>
                </div>
                <div class="col-md-2">
                    <div class="footer-heading">@L["Nav_Catalog"]</div>
                    <ul class="footer-links">
                        <li><a href="/catalog">@L["Nav_Catalog"]</a></li>
                        <li><a href="/compare">@L["Nav_Compare"]</a></li>
                        <li><a href="/favorites">@L["Nav_Favorites"]</a></li>
                    </ul>
                </div>
                <div class="col-md-2">
                    <div class="footer-heading">Компания</div>
                    <ul class="footer-links">
                        <li><a href="/about">@L["Nav_About"]</a></li>
                        <li><a href="/calculator">💳 Кредит</a></li>
                        <li><a href="/sitemap.xml">Sitemap</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <div class="footer-heading">Контакты</div>
                    <ul class="footer-links">
                        <li><a href="#">📍 Кокшетау, ул. Абая 1</a></li>
                        <li><a href="#">🕐 Пн–Вс: 9:00 — 20:00</a></li>
                    </ul>
                </div>
            </div>

            <div class="footer-bottom">
                <span>© @DateTime.Now.Year @L["Site_Name"]. Все права защищены.</span>
                <span>Казахстан · Кредит · Трейд-ин · Гарантия</span>
            </div>
        </div>
    </footer>

    <!-- Sticky CTA (мобайл) -->
    <div class="sticky-cta" id="sticky-cta">
        <a href="#lead-anchor" class="cta-btn cta-call">📞 @L["Lead_Title"]</a>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
            crossorigin="anonymous"></script>
    <script src="~/js/favorite.js" asp-append-version="true"></script>
    <script src="~/js/compare.js" asp-append-version="true"></script>
    <script src="~/js/gallery.js" asp-append-version="true"></script>
    <script src="~/js/sticky-cta.js" asp-append-version="true"></script>

    <script>
        window.currentLang = '@currentCulture';
    </script>

    <script>
        (async function () {
            try {
                const [fav, cmp] = await Promise.all([
                    fetch('/favorites/count').then(r => r.json()),
                    fetch('/compare/count').then(r => r.json())
                ]);
                const favEl = document.getElementById('fav-count');
                const cmpEl = document.getElementById('compare-count');
                if (fav.count > 0) { favEl.textContent = fav.count; favEl.style.display = ''; }
                if (cmp.count > 0) { cmpEl.textContent = cmp.count; cmpEl.style.display = ''; }
            } catch (e) {}
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
